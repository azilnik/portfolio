# Copy to .env and fill in. .env is gitignored.

# Pangram Labs v3 — used by `npm run ai-detect`. Sign up at https://www.pangram.com.
# Without this key, ai-detect exits 0 with a warning (no report generated).
PANGRAM_API_KEY=

# Optional override for the Pangram endpoint. Defaults to the v3 production URL.
# PANGRAM_API_URL=https://text.api.pangram.com/v3
