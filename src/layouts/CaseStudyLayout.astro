---
/**
 * CaseStudyLayout — layout for individual case study pages.
 *
 * Structure:
 *   1. Metadata bar (Industry · Company · Role)
 *   2. Large editorial title
 *   3. Lede paragraph (the one-sentence pitch)
 *   4. Capped hero image
 *   5. Prose body (constrained to the reading column)
 *   6. Impact metrics (if provided)
 *
 * Spacing and title sizing come from the theme's baseline-aligned tokens
 * so every case study shares the same rhythm and proportions.
 */
import PageLayout from "./PageLayout.astro";
import CaseStudyHero from "../components/casestudy/CaseStudyHero.astro";
import ImpactMetrics from "../components/casestudy/ImpactMetrics.astro";
import CaseStudyNav from "../components/casestudy/CaseStudyNav.astro";
import { getImage } from "astro:assets";

interface NavEntry {
  slug: string;
  title: string;
  company: string;
}

interface Props {
  title: string;
  company: string;
  role: string;
  industry: string;
  description: string;
  /** Optional SEO-tuned title. Falls back to `${company} case study`. */
  seoTitle?: string;
  /** Optional SEO-length meta description. Falls back to `description`. */
  seoDescription?: string;
  heroImage: ImageMetadata;
  metrics?: Array<{ label: string; value: string }>;
  prevStudy?: NavEntry;
  nextStudy?: NavEntry;
}

const {
  title,
  company,
  role,
  industry,
  description,
  seoTitle,
  seoDescription,
  heroImage,
  metrics,
  prevStudy,
  nextStudy,
} = Astro.props;

// Title for <title> / OG / Twitter — short and SERP-friendly. BaseLayout
// appends " — Ari Zilnik" if absent. Fallback handles future drafts that
// forget to set seoTitle in frontmatter.
const pageTitle = seoTitle ?? `${company} case study`;

// Meta description — prefer the longer seoDescription, fall back to the
// short lede tagline for studies that haven't added one yet.
const metaDescription = seoDescription ?? description;

// OG card — derive a 1200×630 JPEG from the hero image. Sharp center-crops
// by default, which works well for most screenshots (primary content tends
// to be centered). Crawlers (Slack, iMessage, Twitter, LinkedIn) fetch the
// absolute URL, so we resolve against Astro.site.
const ogCard = await getImage({
  src: heroImage,
  width: 1200,
  height: 630,
  format: "jpeg",
  quality: 85,
});
const ogImage = new URL(ogCard.src, Astro.site).href;

// JSON-LD structured data:
// 1. CreativeWork for the case study itself (headline, creator, image, about).
// 2. BreadcrumbList (Home → Case Studies → this study) — helps SERP breadcrumbs.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const heroAbsolute = new URL(heroImage.src, Astro.site).href;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    headline: title,
    name: seoTitle ?? title,
    description: metaDescription,
    url: canonical,
    image: heroAbsolute,
    about: industry,
    creator: {
      "@type": "Person",
      name: "Ari Zilnik",
      jobTitle: role,
      url: "https://ari.design",
    },
    publisher: {
      "@type": "Person",
      name: "Ari Zilnik",
      url: "https://ari.design",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://ari.design" },
      { "@type": "ListItem", position: 2, name: "Case Studies", item: "https://ari.design/work" },
      { "@type": "ListItem", position: 3, name: seoTitle ?? title, item: canonical },
    ],
  },
];
---

<PageLayout
  title={pageTitle}
  description={metaDescription}
  ogImage={ogImage}
  ogImageAlt={`${title} — case study by Ari Zilnik`}
  ogType="article"
  jsonLd={jsonLd}
>
  <article>
    {/* Header block — metadata, title, lede. The outer container matches
        --theme-content-width so horizontal padding lines up with the site
        header; the inner column matches --theme-prose-width and centers
        inside the shell so the title sits on the same vertical axis as
        the body prose below it. Centering puts the whole reading column
        under the header's visual midpoint on wide displays. */}
    <header
      class="mx-auto px-6"
      style="
        max-width: var(--theme-content-width);
        padding-top: var(--theme-space-7);
        padding-bottom: var(--theme-space-5);
      "
    >
      <div class="mx-auto animate-in" style="max-width: var(--theme-prose-width);">
        {/* Metadata row — small uppercase eyebrow that sits above the title.
            Tufte-ish "margin note" feel without going full sidenote. The
            bottom margin matches the work/about page eyebrows (space-2)
            so the h1 lands at the same y-position across pages. */}
        <div
          class="flex flex-wrap items-center gap-x-6 gap-y-2 text-xs font-medium uppercase"
          style="
            color: var(--theme-text-tertiary);
            letter-spacing: var(--theme-tracking-wider);
            line-height: var(--theme-lh-xs);
            margin-bottom: var(--theme-space-2);
          "
        >
          <span>{industry}</span>
          <span aria-hidden="true" style="color: var(--theme-text-quaternary);">·</span>
          <span>{company}</span>
          <span aria-hidden="true" style="color: var(--theme-text-quaternary);">·</span>
          <span>{role}</span>
        </div>

        {/* Editorial title — sized from --theme-text-5xl, which steps from
            40 → 48 ≥ 768 → 56 ≥ 1024 so the rendered px stays on the 8px
            grid at every viewport. Line-height stays paired so the title
            never breaks rhythm. */}
        <h1
          class="font-heading"
          style="
            color: var(--theme-text-primary);
            font-weight: var(--theme-weight-heading);
            letter-spacing: var(--theme-tracking-tight);
            line-height: var(--theme-lh-5xl);
            font-size: var(--theme-text-5xl);
            max-width: 18ch;
          "
        >
          {title}
        </h1>
      </div>
    </header>

    {/* Hero image — sits inside the same content shell as the header and
        prose. Centered on the prose axis (not left-anchored) so it reads
        as a balanced figure under the title rather than a block jutting
        off the left edge. Capped at --theme-figure-wide so it reads as a
        figure, not a banner. */}
    <div
      class="mx-auto px-6"
      style="max-width: var(--theme-content-width);"
    >
      <div class="mx-auto" style="max-width: var(--theme-figure-wide);">
        <CaseStudyHero image={heroImage} alt={title} />
      </div>
    </div>

    {/* MDX body content — same content shell as the header and hero, so
        the reader's eye stays on one vertical axis. The inner `.prose` is
        45rem (720px) — the natural reading measure — and is centered
        inside the shell by `.prose { margin: 0 auto }` in global.css.
        Wide figures break symmetrically out of the prose column via
        negative margins, staying centered on the reading axis.
        `prose` class styles come from global.css. */}
    <div
      class="mx-auto px-6"
      style="
        max-width: var(--theme-content-width);
        margin-top: var(--theme-space-6);
        margin-bottom: var(--theme-space-6);
      "
    >
      <div class="prose">
        <slot />
      </div>
    </div>

    {/* Impact metrics — only rendered if the case study defines them */}
    {metrics && metrics.length > 0 && (
      <ImpactMetrics metrics={metrics} />
    )}

    {/* Prev/next navigation — sits outside the prose column and metrics
        block so it reads as page-level navigation, not content. Every
        competitive portfolio (Ainara Sainz, Tyler Kotsopoulos) has this
        pattern. Without it, readers hit the bottom and bounce. */}
    <CaseStudyNav prev={prevStudy} next={nextStudy} />
  </article>
</PageLayout>
