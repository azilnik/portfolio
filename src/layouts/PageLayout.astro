---
/**
 * PageLayout — standard page wrapper with Header + Footer.
 *
 * Wraps BaseLayout and adds the sticky header, mobile menu, and footer
 * that appear on every page. Content goes inside the <main> tag.
 *
 * Usage in a page file:
 *   <PageLayout title="Work">
 *     <h1>My content here</h1>
 *   </PageLayout>
 */
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/global/Header.astro";
import MobileMenu from "../components/global/MobileMenu.astro";
import Footer from "../components/global/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "article";
  jsonLd?: Array<Record<string, unknown>>;
}

const { title, description, ogImage, ogImageAlt, ogType, jsonLd } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  ogType={ogType}
  jsonLd={jsonLd}
>
  {/* Skip-to-main-content — hidden above viewport, revealed on keyboard focus.
      WCAG 2.4.1: lets keyboard/screen-reader users bypass the sticky header. */}
  <a
    href="#main-content"
    class="absolute left-0 top-0 z-[200] -translate-y-full rounded-br-md px-4 py-2 text-sm font-semibold transition-transform focus:translate-y-0"
    style="background-color: var(--theme-accent); color: #ffffff;"
  >
    Skip to main content
  </a>

  <Header />
  <MobileMenu />

  {/* Main content area — `flex-1` ensures it fills the space between header and footer */}
  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <Footer />
</BaseLayout>
