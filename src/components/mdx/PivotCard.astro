---
/**
 * PivotCard — a dedicated highlighted block for the pivot moment in a
 * case study.
 *
 * Senior case studies often hinge on a single decision where the product
 * direction changed. This component surfaces that moment as ONE
 * structured block with three short fields: the pivot itself, the cause,
 * and the result. The goal is to make the pivot unmissable to a
 * 10-second scanner and to remove the need to repeat the pivot narrative
 * across multiple paragraphs.
 *
 * Props are structured (no slot content) so the fields are
 * automation-friendly and always render in the same order.
 *
 * Usage in .mdx:
 *   <PivotCard
 *     summary="From materials marketplace to LLM recommendation engine"
 *     cause="Estimators don't browse. The real gap is institutional knowledge."
 *     result="Shipped in 2 months. One customer saved $500K in month one."
 *   />
 */

interface Props {
  /** One-line summary of the pivot — states what changed. */
  summary: string;
  /** Brief cause — the insight or evidence that drove the pivot. */
  cause: string;
  /** Brief result — the product change plus the business outcome. */
  result: string;
}

const { summary, cause, result } = Astro.props;
---

<aside
  class="pivot-card"
  aria-labelledby="pivot-card-heading"
  style="
    margin-top: var(--theme-space-5);
    margin-bottom: var(--theme-space-5);
    padding: var(--theme-space-4);
    background-color: var(--theme-accent-subtle);
    border: 1px solid var(--theme-border-strong);
    border-left: 4px solid var(--theme-accent);
    border-radius: var(--theme-radius-lg);
  "
>
  {/* Heading — labelled so assistive tech announces this block as
      "The pivot." The visible label is small uppercase for hierarchy. */}
  <p
    id="pivot-card-heading"
    style="
      margin: 0 0 var(--theme-space-2) 0;
      font-size: var(--theme-text-xs);
      font-weight: var(--theme-weight-semibold);
      text-transform: uppercase;
      letter-spacing: var(--theme-tracking-wider);
      color: var(--theme-accent);
    "
  >
    The pivot
  </p>

  {/* Summary line — the headline of the pivot, uses the heading font for
      visual weight so a scanner catches it first. */}
  <p
    class="pivot-summary font-heading"
    style="
      margin: 0 0 var(--theme-space-3) 0;
      font-size: var(--theme-text-2xl);
      font-weight: var(--theme-weight-heading);
      line-height: var(--theme-leading-tight);
      color: var(--theme-text-primary);
    "
  >
    {summary}
  </p>

  {/* Cause row — labelled "Why" so readers know this is the insight
      behind the pivot, not a restatement of it. */}
  <div
    class="pivot-row"
    style="
      display: grid;
      grid-template-columns: minmax(4rem, 6rem) 1fr;
      gap: var(--theme-space-2);
      margin-bottom: var(--theme-space-2);
    "
  >
    <span
      style="
        font-size: var(--theme-text-xs);
        font-weight: var(--theme-weight-semibold);
        text-transform: uppercase;
        letter-spacing: var(--theme-tracking-wider);
        color: var(--theme-text-tertiary);
        padding-top: 0.35rem;
      "
    >
      Why
    </span>
    <span
      style="
        font-size: var(--theme-text-lg);
        line-height: var(--theme-leading-normal);
        color: var(--theme-text-primary);
      "
    >
      {cause}
    </span>
  </div>

  {/* Result row — labelled "Result" with the same grid as Why so the
      two rows align and read as a pair. */}
  <div
    class="pivot-row"
    style="
      display: grid;
      grid-template-columns: minmax(4rem, 6rem) 1fr;
      gap: var(--theme-space-2);
    "
  >
    <span
      style="
        font-size: var(--theme-text-xs);
        font-weight: var(--theme-weight-semibold);
        text-transform: uppercase;
        letter-spacing: var(--theme-tracking-wider);
        color: var(--theme-text-tertiary);
        padding-top: 0.35rem;
      "
    >
      Result
    </span>
    <span
      style="
        font-size: var(--theme-text-lg);
        line-height: var(--theme-leading-normal);
        color: var(--theme-text-primary);
      "
    >
      {result}
    </span>
  </div>
</aside>
