---
/**
 * PivotCard — a dedicated highlighted block for the pivot moment in a
 * case study.
 *
 * Senior case studies often hinge on a single decision where the product
 * direction changed. This component surfaces that moment as one
 * structured block with three short fields: the pivot itself, the cause,
 * and the result. The goal is to make the pivot unmissable to a
 * 10-second scanner.
 *
 * Props are structured (no slot content) so the fields are
 * automation-friendly and always render in the same order.
 *
 * Usage in .mdx:
 *   <PivotCard
 *     summary="From materials marketplace to LLM recommendation engine"
 *     cause="Estimators don't browse. The real gap is institutional knowledge."
 *     result="Shipped in 2 months. One customer saved $500K in month one."
 *   />
 */

interface Props {
  /** One-line summary of the pivot — states what changed. */
  summary: string;
  /** Brief cause — the insight or evidence that drove the pivot. */
  cause: string;
  /** Brief result — the product change plus the business outcome. */
  result: string;
}

const { summary, cause, result } = Astro.props;
---

<aside class="pivot-card" aria-labelledby="pivot-heading">
  <p id="pivot-heading" class="pivot-label">The pivot</p>

  {/* Summary — the headline of the pivot. Uses the heading font so a
      scanner catches it before anything else in the card. */}
  <p class="pivot-summary font-heading">{summary}</p>

  {/* Why / Result rows — a definition-list-style pair so the two fields
      visually align and read as cause → effect. */}
  <dl class="pivot-details">
    <div class="pivot-row">
      <dt>Why</dt>
      <dd>{cause}</dd>
    </div>
    <div class="pivot-row">
      <dt>Result</dt>
      <dd>{result}</dd>
    </div>
  </dl>
</aside>

<style>
  .pivot-card {
    margin-top: var(--theme-space-6);
    margin-bottom: var(--theme-space-6);
    padding: var(--theme-space-5) 0;
    border-top: 1px solid var(--theme-border);
    border-bottom: 1px solid var(--theme-border);
  }

  .pivot-label {
    margin: 0 0 var(--theme-space-2);
    font-size: var(--theme-text-xs);
    font-weight: var(--theme-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--theme-tracking-wider);
    color: var(--theme-accent);
  }

  .pivot-summary {
    margin: 0 0 var(--theme-space-3);
    font-size: var(--theme-text-2xl);
    font-weight: var(--theme-weight-heading);
    line-height: var(--theme-leading-tight);
    color: var(--theme-text-primary);
  }

  /* Strip browser defaults from the definition list so the rows control
     all spacing. Using <dl>/<dt>/<dd> gives the Why/Result pairs semantic
     meaning (term + definition) without extra divs. */
  .pivot-details {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--theme-space-2);
  }

  .pivot-row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--theme-space-2);
  }

  .pivot-row dt {
    font-size: var(--theme-text-xs);
    font-weight: var(--theme-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--theme-tracking-wider);
    color: var(--theme-text-tertiary);
    /* Nudge the small label down so its x-height aligns with the larger
       dd text beside it. */
    padding-top: 0.3rem;
  }

  .pivot-row dd {
    margin: 0;
    font-size: var(--theme-text-lg);
    line-height: var(--theme-leading-normal);
    color: var(--theme-text-primary);
  }
</style>
