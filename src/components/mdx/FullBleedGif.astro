---
/**
 * FullBleedGif — animated GIF variant of FullBleedImage. Uses a plain
 * <img> tag because Astro's Image component (Sharp) strips animation
 * frames from GIFs. GIFs must live in `public/videos/`.
 *
 * Supports the same `size` prop as FullBleedImage ("column", "wide",
 * "full"). The width classes are defined in src/styles/global.css.
 *
 * Usage in .mdx:
 *   <FullBleedGif src="/videos/my-anim.gif" alt="…" />
 *   <FullBleedGif src="/videos/my-anim.gif" alt="…" size="wide" />
 */

type FigureSize = "column" | "wide" | "full";

interface Props {
  src: string;
  alt: string;
  /** Width treatment. Defaults to "column" (stays in the prose column). */
  size?: FigureSize;
  /** Optional caption shown below the image. */
  caption?: string;
}

const { src, alt, size = "column", caption } = Astro.props;

const sizeClass = {
  column: "figure-column",
  wide: "figure-wide",
  full: "figure-full",
}[size];
---

<figure class={sizeClass}>
  <img
    src={src}
    alt={alt}
    class="w-full h-auto"
    loading="lazy"
  />
  {caption && (
    <figcaption
      class="text-sm"
      style="color: var(--theme-text-tertiary); line-height: var(--theme-lh-sm); margin-top: var(--theme-space-2);"
    >
      {caption}
    </figcaption>
  )}
</figure>
