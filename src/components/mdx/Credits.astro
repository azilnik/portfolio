---
/**
 * Credits — team attribution at the bottom of a case study.
 *
 * Inspired by Ainara Sainz, who credits the full team on every project.
 * A Credits section signals leadership and collaboration more
 * powerfully than any paragraph about org structure.
 *
 * Usage in MDX:
 *   <Credits
 *     credits={[
 *       { role: "Design", people: "Ari Zilnik" },
 *       { role: "Product", people: "Jane Doe", url: "https://linkedin.com/in/janedoe" },
 *       { role: "Engineering", people: "Alice, Bob, Charlie" },
 *     ]}
 *     note="Made with ... at Join."
 *   />
 */

interface CreditEntry {
  role: string;
  people: string;
  /** Optional link — when provided, the people text becomes a hyperlink. */
  url?: string;
}

interface Props {
  credits: CreditEntry[];
  note?: string;
}

const { credits, note } = Astro.props;
---

<div
  style="
    margin-top: var(--theme-space-6);
    padding-top: var(--theme-space-4);
    border-top: 1px solid var(--theme-border);
  "
>
  <p
    class="text-xs font-semibold uppercase"
    style="
      color: var(--theme-text-tertiary);
      letter-spacing: var(--theme-tracking-wider);
      margin-bottom: var(--theme-space-3);
    "
  >
    Credits
  </p>

  <div class="space-y-1">
    {credits.map((c) => (
      <p
        class="text-sm"
        style="color: var(--theme-text-secondary);"
      >
        <span class="font-semibold" style="color: var(--theme-text-primary);">
          {c.role}:
        </span>{" "}
        {c.url ? (
          <a
            href={c.url}
            target="_blank"
            rel="noopener noreferrer"
            class="credit-link"
          >
            {c.people}
          </a>
        ) : (
          c.people
        )}
      </p>
    ))}
  </div>

  {note && (
    <p
      class="text-sm"
      style="
        color: var(--theme-text-tertiary);
        margin-top: var(--theme-space-3);
      "
    >
      {note}
    </p>
  )}
</div>

<style>
  /* Subtle link style that matches the secondary text color at rest
     and shifts to the accent color on hover. No underline at rest
     so links don't visually compete with the credit labels. */
  .credit-link {
    color: var(--theme-text-secondary);
    text-decoration: none;
  }
  .credit-link:hover {
    color: var(--theme-accent);
    text-decoration: underline;
  }
</style>
