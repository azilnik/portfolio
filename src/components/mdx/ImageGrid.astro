---
/**
 * ImageGrid — display 2–3 images side by side in a responsive grid.
 *
 * On mobile, images stack vertically. On desktop, they sit in a row.
 * Uses the same `size` prop as FullBleedImage so a grid can span the
 * prose column (default), a wide breakout, or a capped full-bleed.
 *
 * Usage in .mdx:
 *   <ImageGrid images={[
 *     { src: img1, alt: "First screen" },
 *     { src: img2, alt: "Second screen" },
 *   ]} />
 *
 *   <ImageGrid size="wide" images={[…]} caption="Before and after" />
 */
import { Image } from "astro:assets";
import { resolveContentImage } from "../../lib/contentImages";

type FigureSize = "column" | "wide" | "full";

interface GridImage {
  src: ImageMetadata | string;
  alt: string;
}

interface Props {
  images: GridImage[];
  /** Width treatment. Defaults to "wide" because grids usually need room. */
  size?: FigureSize;
  /** Optional caption shown below the grid. */
  caption?: string;
}

const { images, size = "wide", caption } = Astro.props;

const sizeClass = {
  column: "figure-column",
  wide: "figure-wide",
  full: "figure-full",
}[size];

// 2-up on tablet/desktop, 3-up on large desktop when there are 3+ images.
const colsClass =
  images.length === 2
    ? "grid-cols-1 sm:grid-cols-2"
    : "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3";

// Request only the widths we'll actually render at this grid size.
const widthsForSize = {
  column: [320, 480],
  wide: [400, 600, 800],
  full: [500, 700, 900],
}[size];

const sizesForSize =
  images.length === 2
    ? "(min-width: 640px) 50vw, 100vw"
    : "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw";
---

<figure class={sizeClass}>
  <div class:list={["grid gap-4", colsClass]}>
    {images.map((img) => (
      <Image
        src={resolveContentImage(img.src)}
        alt={img.alt}
        widths={widthsForSize}
        sizes={sizesForSize}
        class="w-full h-auto"
      />
    ))}
  </div>
  {caption && (
    <figcaption
      class="text-sm"
      style="color: var(--theme-text-tertiary); line-height: var(--theme-lh-sm); margin-top: var(--theme-space-2);"
    >
      {caption}
    </figcaption>
  )}
</figure>
