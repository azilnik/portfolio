---
/**
 * VideoPlayer — HTML5 video with GIF fallback for case study demos.
 *
 * Renders an autoplay, muted, looping video. Supports the same `size`
 * prop as FullBleedImage so videos can sit in the prose column or
 * break out for more detail.
 *
 * Usage in .mdx:
 *   <VideoPlayer
 *     src="/videos/my-demo.mp4"
 *     fallback="/videos/my-demo.gif"
 *     alt="Demo of the new checkout flow"
 *   />
 *
 * Video files go in `public/videos/`. Use `scripts/convert-video.sh`
 * to convert screen recordings to mp4 + gif.
 */

type FigureSize = "column" | "wide" | "full";

interface Props {
  /** Path to the .mp4 file (in public/videos/). */
  src: string;
  /** Path to the .gif fallback (in public/videos/). */
  fallback: string;
  /** Alt text describing the video content. */
  alt: string;
  /** Width treatment. Defaults to "wide" because UI demos need room. */
  size?: FigureSize;
  /** Optional caption shown below the video. */
  caption?: string;
}

const { src, fallback, alt, size = "wide", caption } = Astro.props;

const sizeClass = {
  column: "figure-column",
  wide: "figure-wide",
  full: "figure-full",
}[size];
---

<figure class={sizeClass}>
  <div class="overflow-hidden" style="border-radius: var(--theme-image-radius);">
    {/* HTML5 video — autoplay, muted, looping (silent background demo) */}
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-auto block"
      aria-label={alt}
    >
      <source src={src} type="video/mp4" />
      {/* Fallback: if <video> is not supported, show the GIF instead */}
      <img src={fallback} alt={alt} class="w-full h-auto" loading="lazy" />
    </video>
  </div>
  {caption && (
    <figcaption
      class="text-sm"
      style="color: var(--theme-text-tertiary); line-height: var(--theme-lh-sm); margin-top: var(--theme-space-2);"
    >
      {caption}
    </figcaption>
  )}
</figure>
