---
/**
 * VideoPlayer — autoplaying, muted, looping HTML5 video for case study demos.
 *
 * Supports both MP4 (h264) and WebM (vp9) sources for browser efficiency.
 * Pauses playback when scrolled off-screen via IntersectionObserver to keep
 * long case studies light. Falls back to a static GIF for ancient browsers.
 *
 * Usage in .mdx:
 *   <VideoPlayer
 *     src="/videos/my-demo.mp4"
 *     webm="/videos/my-demo.webm"
 *     fallback="/videos/my-demo.gif"
 *     alt="Demo of the new checkout flow"
 *   />
 *
 * Use `scripts/convert-video.sh` to produce the encoded files.
 */

type FigureSize = "column" | "wide" | "full";

interface Props {
  /** Path to the .mp4 file (in public/videos/). */
  src: string;
  /** Optional .webm source — preferred by Chromium/Firefox for smaller payloads. */
  webm?: string;
  /** Path to the .gif fallback (in public/videos/). */
  fallback: string;
  /** Alt text describing the video content. */
  alt: string;
  /** Width treatment. Defaults to "wide" because UI demos need room. */
  size?: FigureSize;
  /** Optional caption shown below the video. */
  caption?: string;
}

const { src, webm, fallback, alt, size = "wide", caption } = Astro.props;

const sizeClass = {
  column: "figure-column",
  wide: "figure-wide",
  full: "figure-full",
}[size];
---

<figure class={sizeClass}>
  <div class="overflow-hidden" style="border-radius: var(--theme-image-radius);">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="w-full h-auto block scroll-pause-video"
      aria-label={alt}
    >
      {webm && <source src={webm} type="video/webm" />}
      <source src={src} type="video/mp4" />
      <img src={fallback} alt={alt} class="w-full h-auto" loading="lazy" />
    </video>
  </div>
  {caption && (
    <figcaption
      class="text-sm"
      style="color: var(--theme-text-tertiary); line-height: var(--theme-lh-sm); margin-top: var(--theme-space-2);"
    >
      {caption}
    </figcaption>
  )}
</figure>

<script>
  // Pause videos when scrolled out of view so off-screen demos stop decoding
  // frames. Re-plays when they re-enter the viewport.
  const setupScrollPause = () => {
    const videos = document.querySelectorAll<HTMLVideoElement>(".scroll-pause-video");
    if (!videos.length || typeof IntersectionObserver === "undefined") return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const video = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            // play() returns a promise that rejects if autoplay is blocked;
            // swallow it because the video is muted so it should always succeed.
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        }
      },
      { rootMargin: "100px 0px", threshold: 0 },
    );

    videos.forEach((video) => observer.observe(video));
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupScrollPause);
  } else {
    setupScrollPause();
  }
</script>
