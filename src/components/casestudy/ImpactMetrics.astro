---
/**
 * ImpactMetrics — a row of 1–3 key metrics shown at the end of a case study.
 *
 * Each metric has a `value` (the big number/stat) and a `label` (what it means).
 * Displayed in a 3-column grid that stacks on mobile. The section sits on
 * the baseline grid and uses a hairline divider instead of a heavy border.
 */

interface Props {
  metrics: Array<{ label: string; value: string }>;
}

const { metrics } = Astro.props;
---

<section
  class="border-t"
  style="
    background-color: var(--theme-bg);
    border-color: var(--theme-border);
    padding-top: var(--theme-space-6);
    padding-bottom: var(--theme-space-6);
    margin-top: var(--theme-space-5);
  "
>
  {/* Outer shell matches --theme-content-width for horizontal padding
      parity with the site header. The inner block is capped at
      --theme-figure-wide (928px) and centered, matching the hero image
      width at the top of the case study. This gives the case study a
      visual "book end" effect — hero and impact share the same width
      and the same centered axis as the prose between them. */}
  <div
    class="mx-auto px-6"
    style="max-width: var(--theme-content-width);"
  >
    <div class="mx-auto" style="max-width: var(--theme-figure-wide);">
      <p
        class="text-xs font-semibold uppercase"
        style="
          color: var(--theme-text-tertiary);
          letter-spacing: var(--theme-tracking-wider);
          margin-bottom: var(--theme-space-4);
        "
      >
        Impact
      </p>

      <div class="grid grid-cols-1 gap-12 sm:grid-cols-3">
        {metrics.map((metric) => (
          <div>
            {/* Display number — large, accent-colored, tabular figures so
                multi-metric rows align cleanly regardless of digit width. */}
            <p
              class="font-heading"
              style="
                color: var(--theme-accent);
                font-size: var(--theme-text-5xl);
                line-height: var(--theme-leading-tight);
                letter-spacing: var(--theme-tracking-tight);
                font-weight: var(--theme-weight-heading);
                font-variant-numeric: tabular-nums;
              "
            >
              {metric.value}
            </p>
            <p
              class="mt-3 leading-snug"
              style="
                color: var(--theme-text-secondary);
                font-size: var(--theme-text-sm);
                max-width: 32ch;
              "
            >
              {metric.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
