---
/**
 * ImpactMetrics — a row of 1–3 key metrics shown at the end of a case study.
 *
 * Each metric has a `value` (the big number/stat) and a `label` (what it means).
 * Displayed in a 3-column grid that stacks on mobile.
 */

interface Props {
  metrics: Array<{ label: string; value: string }>;
}

const { metrics } = Astro.props;
---

<section class="mt-8 py-16 border-t" style="background-color: var(--theme-bg); border-color: var(--theme-border);">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-3">
      {metrics.map((metric) => (
        <div class="text-center">
          {/* Short stat rendered large; label is the explanatory phrase below */}
          <p class="font-heading text-4xl font-bold leading-tight" style="color: var(--theme-accent);">{metric.value}</p>
          <p class="mt-3 text-sm leading-relaxed" style="color: var(--theme-text-secondary);">{metric.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
