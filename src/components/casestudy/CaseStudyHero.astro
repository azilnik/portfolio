---
/**
 * CaseStudyHero — capped-width hero image for case study pages.
 *
 * Renders at the asset's native aspect ratio so screenshots display
 * exactly as captured. The wrapper provides the rounded corner and
 * shadow; the image fills its width and lets height follow naturally.
 */
import { Image } from "astro:assets";

interface Props {
  image: ImageMetadata;
  alt: string;
  /** Case study slug — used to pair this hero with its thumbnail tile
      on listing pages via the View Transitions API. */
  slug: string;
}

const { image, alt, slug } = Astro.props;
---

<div
  class="w-full overflow-hidden animate-in"
  style="border-radius: var(--theme-image-radius); box-shadow: var(--shadow-elevation-medium); --delay: 80ms;"
  transition:name={`study-thumb-${slug}`}
>
  <Image
    src={image}
    alt={alt}
    widths={[720, 960, 1280, 1600]}
    sizes="(min-width: 1024px) 960px, 100vw"
    class="w-full h-auto"
    loading="eager"
  />
</div>
