---
/**
 * CaseStudyHero — capped-width hero image for case study pages.
 *
 * Sized as a 16:9 editorial landscape so it sits with the introductory
 * paragraph instead of dominating the page. Source screenshots are
 * usually square or 4:3, so we use `object-fit: cover` to crop into
 * the 16:9 frame and `object-position` can be overridden per image
 * if the crop cuts off something important.
 *
 * On mobile the frame relaxes to 4:3 so the hero doesn't feel like a
 * narrow slit on a phone held in portrait.
 */
import { Image } from "astro:assets";

interface Props {
  image: ImageMetadata;
  alt: string;
}

const { image, alt } = Astro.props;
---

<div
  class="case-study-hero w-full overflow-hidden animate-in"
  style="border-radius: var(--theme-image-radius); box-shadow: var(--shadow-elevation-medium); --delay: 80ms;"
>
  <Image
    src={image}
    alt={alt}
    widths={[720, 960, 1280, 1600]}
    sizes="(min-width: 1024px) 960px, 100vw"
    class="w-full h-full object-cover"
    style="object-position: center top;"
    loading="eager"
  />
</div>

<style>
  /* Mobile: 4:3 so the hero isn't a letterbox on phones. */
  .case-study-hero {
    aspect-ratio: 4 / 3;
  }

  /* Desktop: 16:9 editorial landscape. Keeps the hero in a calm
     proportion next to the title block. */
  @media (min-width: 768px) {
    .case-study-hero {
      aspect-ratio: 16 / 9;
    }
  }
</style>
