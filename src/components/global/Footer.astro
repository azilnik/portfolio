---
/**
 * Footer — dark CTA section at the bottom of every page.
 *
 * Includes a "Get in touch" call-to-action and a link back to the
 * work page, matching the style of the current ari.design footer.
 */
---

<footer class="bg-gray-950 text-white">
  <div class="mx-auto max-w-6xl px-6 py-20 text-center">
    {/* Main CTA */}
    <p class="text-sm font-medium uppercase tracking-widest text-gray-400 mb-4">
      Interested in working together?
    </p>
    <h2 class="font-heading text-4xl font-bold md:text-5xl mb-8">
      Get in touch
    </h2>
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="mailto:ari@ari.design"
        class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-hover"
      >
        Say hello
      </a>
      <a
        href="/work"
        class="inline-flex items-center gap-2 rounded-full border border-white/20 px-8 py-3 text-sm font-semibold text-white transition-colors hover:border-white/40"
      >
        See my work
      </a>
    </div>

    {/* Copyright */}
    <p class="mt-16 text-xs text-gray-500">
      &copy; {new Date().getFullYear()} Ari Zilnik. All rights reserved.
    </p>
  </div>
</footer>
