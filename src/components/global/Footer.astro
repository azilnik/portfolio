---
/**
 * Footer — extreme reduction. Email and copyright. Nothing else.
 */
---

<footer
  style="
    background-color: var(--theme-footer-bg);
    color: var(--theme-footer-text);
    margin-top: var(--theme-space-7);
  "
>
  <div
    class="mx-auto px-6 text-center"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-6);
      padding-bottom: var(--theme-space-6);
    "
  >
    <a
      href="mailto:ari@zilnik.com"
      style="
        color: var(--theme-footer-text);
        text-decoration: underline;
        text-underline-offset: 4px;
      "
      data-goatcounter-click="contact-footer"
    >
      ari@zilnik.com
    </a>

    <p
      class="text-xs"
      style="
        color: var(--theme-footer-muted);
        margin-top: var(--theme-space-3);
      "
    >
      &copy; {new Date().getFullYear()} Ari Zilnik
    </p>
  </div>
</footer>
