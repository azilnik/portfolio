---
/**
 * Footer — CTA section and social links at the bottom of every page.
 *
 * Warm Signal: two-column layout with Fraunces heading, green accent
 * CTA button, warm dark brown background.
 */
---

<footer
  style="
    background-color: #2A2520;
    color: #EDE8E0;
    margin-top: var(--theme-space-7);
  "
>
  <div
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-6);
    "
  >
    {/* Two-column layout: CTA left, links right */}
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">

      {/* Left: CTA block */}
      <div>
        <h2
          class="font-heading"
          style="
            font-family: var(--theme-font-heading);
            font-weight: 700;
            letter-spacing: -0.025em;
            line-height: 1.08;
            font-size: clamp(2rem, 1.6rem + 1.8vw, 2.5rem);
          "
        >
          Let's work together.
        </h2>
        <div style="margin-top: 2rem;">
          <a
            href="mailto:ari@zilnik.com"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold transition-colors"
            style="background-color: #2A5F4F; color: #ffffff; border-radius: 4px;"
            data-goatcounter-click="contact-footer"
          >
            ari@zilnik.com
          </a>
        </div>
      </div>

      {/* Right: Links and location */}
      <div class="flex flex-col gap-4 text-sm md:items-end md:text-right">
        <div class="flex gap-5">
          <a
            href="https://www.linkedin.com/in/azilnik/"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:underline"
            style="color: #EDE8E0;"
            data-goatcounter-click="linkedin-footer"
          >
            LinkedIn
          </a>
          <a
            href="https://github.com/azilnik"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:underline"
            style="color: #EDE8E0;"
            data-goatcounter-click="github-footer"
          >
            GitHub
          </a>
        </div>

        <p style="color: #8A8580;">
          Toronto, Canada
        </p>
      </div>
    </div>

    {/* Copyright line */}
    <p
      class="text-xs"
      style="
        color: #8A8580;
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.08);
      "
    >
      &copy; {new Date().getFullYear()} Ari Zilnik
    </p>
  </div>
</footer>
