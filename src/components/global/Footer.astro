---
/**
 * Footer — CTA section at the bottom of every page.
 *
 * Includes a "Get in touch" call-to-action and a link back to the
 * work page. Uses theme CSS variables for all colors.
 */
---

<footer style="background-color: var(--theme-footer-bg); color: var(--theme-footer-text);">
  <div class="mx-auto max-w-6xl px-6 py-20 text-center">
    {/* Main CTA */}
    <p
      class="text-sm font-medium uppercase tracking-widest mb-4"
      style="color: var(--theme-footer-muted);"
    >
      Interested in working together?
    </p>
    <h2 class="font-heading text-4xl font-bold md:text-5xl mb-8">
      Get in touch
    </h2>
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="mailto:ari@ari.design"
        class="inline-flex items-center gap-2 rounded-full px-8 py-3 text-sm font-semibold text-white transition-colors"
        style="background-color: var(--theme-accent);"
      >
        Say hello
      </a>
      <a
        href="/work"
        class="inline-flex items-center gap-2 rounded-full border px-8 py-3 text-sm font-semibold transition-colors"
        style="border-color: var(--theme-footer-border); color: var(--theme-footer-text);"
      >
        See my work
      </a>
    </div>

    {/* Copyright */}
    <p class="mt-16 text-xs" style="color: var(--theme-footer-muted);">
      &copy; {new Date().getFullYear()} Ari Zilnik. All rights reserved.
    </p>
  </div>
</footer>
