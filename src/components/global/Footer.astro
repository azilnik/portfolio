---
/**
 * Footer — centered CTA and social links. Dark Gravity theme.
 */
---

<footer style="background-color: #000000; margin-top: var(--theme-space-7);">
  <div
    class="mx-auto px-6 text-center"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-6);
      border-top: 1px solid #2A2825;
    "
  >
    <h2
      class="font-heading"
      style="
        color: #D4A853;
        font-weight: var(--theme-weight-heading);
        letter-spacing: var(--theme-tracking-tight);
        line-height: var(--theme-leading-tight);
        font-size: var(--theme-text-4xl);
      "
    >
      Let's connect.
    </h2>

    <div style="margin-top: var(--theme-space-4);">
      <a
        href="mailto:ari@zilnik.com"
        class="inline-flex items-center gap-2 text-sm font-semibold transition-colors"
        style="color: #D4A853;"
        data-goatcounter-click="contact-footer"
      >
        ari@zilnik.com
      </a>
    </div>

    <div class="flex justify-center gap-5" style="margin-top: var(--theme-space-4);">
      <a
        href="https://www.linkedin.com/in/azilnik/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm transition-colors hover:underline"
        style="color: #9B9590;"
        data-goatcounter-click="linkedin-footer"
      >
        LinkedIn
      </a>
      <span style="color: #6B6560;">·</span>
      <a
        href="https://github.com/azilnik"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm transition-colors hover:underline"
        style="color: #9B9590;"
        data-goatcounter-click="github-footer"
      >
        GitHub
      </a>
    </div>

    <p class="text-sm" style="color: #6B6560; margin-top: var(--theme-space-3);">
      Toronto, Canada
    </p>

    <p
      class="text-xs"
      style="color: #6B6560; margin-top: var(--theme-space-6);"
    >
      &copy; {new Date().getFullYear()} Ari Zilnik
    </p>
  </div>
</footer>
