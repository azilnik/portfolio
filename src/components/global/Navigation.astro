---
/**
 * Navigation — shared link list for Header and MobileMenu.
 *
 * Renders the nav links from `src/data/navigation.ts` as a list of <a> tags.
 * The active page gets a bold style. Pass `vertical` to stack links vertically
 * (used in the mobile menu).
 *
 * Uses theme CSS variables so link colors adapt to the active theme.
 */
import { navLinks } from "../../data/navigation";

interface Props {
  /** Stack links vertically instead of horizontally. */
  vertical?: boolean;
  /** CSS classes to add to the <nav> wrapper. */
  class?: string;
}

const { vertical = false, class: className = "" } = Astro.props;

// Get the current page path to highlight the active link.
const currentPath = Astro.url.pathname;
---

<nav class={className}>
  <ul class:list={[
    "flex gap-6",
    vertical ? "flex-col gap-8 text-2xl" : "flex-row items-center text-sm",
  ]}>
    {navLinks.map((link) => {
      // A link is "active" if the current path starts with the link's href.
      // Exception: "/" would match everything, so we only mark it active on exact match.
      const isActive =
        link.href === "/"
          ? currentPath === "/"
          : currentPath.startsWith(link.href) && link.href !== "#";

      return (
        <li>
          <a
            href={link.href}
            class="transition-colors"
            style={isActive
              ? "font-weight: 600; color: var(--theme-accent);"
              : "color: var(--theme-text-secondary);"}
            {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {link.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
