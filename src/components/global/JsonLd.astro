---
/**
 * JsonLd — emit a single JSON-LD structured data block.
 *
 * Usage:
 *   <JsonLd data={{ "@context": "https://schema.org", "@type": "Person", ... }} />
 *
 * Pages typically pass the data through `BaseLayout`'s `jsonLd` prop (an array)
 * so the markup stays together in <head>. Use this component directly when
 * you want to emit a block outside the BaseLayout-managed set.
 *
 * Serializes via JSON.stringify with no indentation so the emitted payload is
 * compact. Schema.org validators don't care about whitespace.
 */
interface Props {
  data: Record<string, unknown>;
}

const { data } = Astro.props;
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(data)}
/>
