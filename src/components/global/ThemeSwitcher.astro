---
/**
 * ThemeSwitcher — light/dark toggle button.
 *
 * Switches between the two themes: gradient-editorial (light) and
 * dark-editorial (dark). Selection persists via localStorage.
 *
 * Designed to sit inline in the Header, not as a floating overlay.
 */
---

<button
  id="theme-toggle"
  class="flex h-8 w-8 items-center justify-center rounded-md transition-colors"
  style="color: var(--theme-text-secondary);"
  aria-label="Toggle dark mode"
  title="Toggle dark mode"
>
  {/* Sun icon — shown when dark theme is active (clicking switches to light) */}
  <svg
    id="theme-icon-sun"
    class="hidden h-[18px] w-[18px]"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.5"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
  </svg>

  {/* Moon icon — shown when light theme is active (clicking switches to dark) */}
  <svg
    id="theme-icon-moon"
    class="hidden h-[18px] w-[18px]"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.5"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
  </svg>
</button>

<script>
  /**
   * Light/dark toggle — persists selection in localStorage,
   * applies via data-theme attribute on <html>.
   *
   * Light = gradient-editorial, Dark = dark-editorial.
   */
  function initThemeToggle() {
    const toggle = document.getElementById("theme-toggle");
    const sunIcon = document.getElementById("theme-icon-sun");
    const moonIcon = document.getElementById("theme-icon-moon");
    if (!toggle || !sunIcon || !moonIcon) return;

    function updateIcons() {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark-editorial";
      /* Show sun when dark (so user can switch to light),
         show moon when light (so user can switch to dark) */
      sunIcon!.classList.toggle("hidden", !isDark);
      moonIcon!.classList.toggle("hidden", isDark);
    }

    toggle.addEventListener("click", () => {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark-editorial";
      const newTheme = isDark ? "gradient-editorial" : "dark-editorial";
      document.documentElement.setAttribute("data-theme", newTheme);
      localStorage.setItem("portfolio-theme", newTheme);
      updateIcons();
    });

    updateIcons();
  }

  initThemeToggle();
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>

{/* Inline script to prevent flash of wrong theme — runs before paint */}
<script is:inline>
  (function() {
    var t = localStorage.getItem("portfolio-theme");
    if (t === "dark-editorial") {
      document.documentElement.setAttribute("data-theme", "dark-editorial");
    } else {
      document.documentElement.setAttribute("data-theme", "gradient-editorial");
    }
  })();
</script>
