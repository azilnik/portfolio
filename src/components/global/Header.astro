---
/**
 * Header — sticky site header with logo and navigation.
 *
 * On desktop (md+), shows horizontal nav links.
 * On mobile (<md), shows a hamburger button that toggles the MobileMenu.
 *
 * Uses theme CSS variables for colors so the header adapts to the active theme.
 */
import Navigation from "./Navigation.astro";
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur-md"
  style="border-color: var(--theme-header-border); background-color: var(--theme-header-bg);"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    {/* Logo / home link */}
    <a
      href="/"
      class="font-heading text-lg font-bold tracking-tight"
      style="color: var(--theme-text-primary);"
    >
      Ari Zilnik
    </a>

    {/* Desktop nav — hidden on mobile */}
    <Navigation class="hidden md:block" />

    {/* Mobile hamburger button — visible on small screens only */}
    <button
      id="mobile-menu-toggle"
      class="flex items-center justify-center md:hidden"
      aria-label="Open navigation menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" style="color: var(--theme-text-secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>
