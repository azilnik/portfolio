---
/**
 * Header — sticky site header with logo and navigation.
 *
 * Warm Signal: Fraunces serif logo, warm sand bg with blur.
 */
import Navigation from "./Navigation.astro";
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur-md"
  style="border-color: var(--theme-header-border); background-color: var(--theme-header-bg);"
>
  <div
    class="mx-auto flex items-center justify-between px-6 py-4"
    style="max-width: var(--theme-content-width);"
  >
    <a
      href="/"
      class="font-heading text-lg tracking-tight"
      style="color: var(--theme-text-primary); font-weight: 700; font-family: var(--theme-font-heading);"
    >
      Ari Zilnik
    </a>

    {/* Desktop nav */}
    <div class="hidden items-center md:flex">
      <Navigation />
    </div>

    {/* Mobile hamburger */}
    <div class="flex items-center md:hidden">
      <button
        id="mobile-menu-toggle"
        class="flex items-center justify-center"
        aria-label="Open navigation menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" style="color: var(--theme-text-secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
