---
/**
 * Header — sticky site header with logo and navigation.
 *
 * On desktop (md+), shows horizontal nav links.
 * On mobile (<md), shows a hamburger button that toggles the MobileMenu.
 *
 * Refined for the light-first theme: cleaner separator, tighter spacing.
 * Uses theme CSS variables for colors so the header adapts to the active theme.
 */
import Navigation from "./Navigation.astro";
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur-md"
  style="border-color: #2A2825; background-color: rgba(13, 13, 13, 0.9);"
>
  <div
    class="mx-auto flex items-center justify-between px-6 py-4"
    style="max-width: var(--theme-content-width);"
  >
    {/* Logo / home link — name only, bold, minimal. Matches the
        competitive set: Danny uses "DW", Tyler uses "TK", Ainara uses
        her full name. Full name signals confidence at the senior level. */}
    <a
      href="/"
      class="font-heading text-lg tracking-tight"
      style="color: #E8E4DF; font-weight: var(--theme-weight-heading);"
    >
      Ari Zilnik
    </a>

    {/* Desktop nav */}
    <div class="hidden items-center md:flex">
      <Navigation />
    </div>

    {/* Mobile hamburger */}
    <div class="flex items-center md:hidden">
      <button
        id="mobile-menu-toggle"
        class="flex items-center justify-center"
        aria-label="Open navigation menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" style="color: #9B9590;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
