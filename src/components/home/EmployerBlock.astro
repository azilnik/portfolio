---
/**
 * EmployerBlock — a section for one employer on the homepage.
 *
 * Shows the company details, description, metrics grid, and linked
 * case study thumbnails from that employer.
 */
import type { Employer } from "../../data/employers";
import type { CollectionEntry } from "astro:content";
import MetricItem from "./MetricItem.astro";
import { Image } from "astro:assets";

interface Props {
  employer: Employer;
  /** Case studies that belong to this employer (filtered from the full collection). */
  caseStudies: CollectionEntry<"work">[];
}

const { employer, caseStudies } = Astro.props;
---

<div class="py-16 border-t border-gray-100 first:border-t-0">
  {/* Header — company name, role, dates */}
  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <div>
      <h3 class="font-heading text-2xl font-bold text-gray-900">{employer.company}</h3>
      <p class="text-sm text-gray-500">{employer.role}</p>
    </div>
    <p class="text-sm text-gray-400">{employer.dateRange}</p>
  </div>

  {/* Tagline */}
  <p class="mt-3 font-heading text-lg font-medium text-gray-700">{employer.tagline}</p>

  {/* Description */}
  <p class="mt-3 leading-relaxed text-gray-500">{employer.description}</p>

  {/* Metrics grid — 3 columns */}
  <div class="mt-8 grid grid-cols-3 gap-4 rounded-xl bg-gray-50 p-6">
    {employer.metrics.map((metric) => (
      <MetricItem label={metric.label} value={metric.value} />
    ))}
  </div>

  {/* Case study thumbnails — linked to their detail pages */}
  {caseStudies.length > 0 && (
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {caseStudies.map((study) => (
        <a
          href={`/work/${study.id}`}
          class="group overflow-hidden rounded-xl border border-gray-100 transition-shadow hover:shadow-md"
        >
          <Image
            src={study.data.thumbnail}
            alt={study.data.thumbnailAlt}
            widths={[320, 480]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          />
          <div class="p-4">
            <p class="text-xs font-medium uppercase tracking-wider text-gray-400">{study.data.company}</p>
            <p class="mt-1 font-medium text-gray-900">{study.data.title}</p>
          </div>
        </a>
      ))}
    </div>
  )}
</div>
