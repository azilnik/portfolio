---
/**
 * EmployerBlock — a section for one employer on the homepage.
 *
 * Shows the company details, description, metrics grid, and linked
 * case study thumbnails from that employer.
 */
import type { Employer } from "../../data/employers";
import type { CollectionEntry } from "astro:content";
import MetricItem from "./MetricItem.astro";
import { Image } from "astro:assets";

interface Props {
  employer: Employer;
  /** Case studies that belong to this employer (filtered from the full collection). */
  caseStudies: CollectionEntry<"work">[];
}

const { employer, caseStudies } = Astro.props;
---

<div class="py-16 border-t first:border-t-0" style="border-color: var(--theme-border);">
  {/* Header — company name, role, dates */}
  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <div>
      <h3
        class="font-heading text-2xl font-bold"
        style="color: var(--theme-text-primary);"
      >{employer.company}</h3>
      <p class="text-sm" style="color: var(--theme-text-secondary);">{employer.role}</p>
    </div>
    <p class="text-sm" style="color: var(--theme-text-tertiary);">{employer.dateRange}</p>
  </div>

  {/* Tagline */}
  <p
    class="mt-3 font-heading text-lg font-medium"
    style="color: var(--theme-text-secondary);"
  >{employer.tagline}</p>

  {/* Description */}
  <p class="mt-3 leading-relaxed" style="color: var(--theme-text-secondary);">{employer.description}</p>

  {/* Metrics grid — 3 columns */}
  <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4 rounded-xl p-6" style="background-color: var(--theme-bg);">
    {employer.metrics.map((metric) => (
      <MetricItem label={metric.label} value={metric.value} />
    ))}
  </div>

  {/* Case study thumbnails — linked to their detail pages */}
  {caseStudies.length > 0 && (
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {caseStudies.map((study) => (
        <a
          href={`/work/${study.id}`}
          class="group overflow-hidden rounded-xl border transition-shadow hover:shadow-md"
          style="border-color: var(--theme-border);"
        >
          <Image
            src={study.data.thumbnail}
            alt={study.data.thumbnailAlt}
            widths={[320, 480]}
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          />
          <div class="p-4" style="background-color: var(--theme-surface);">
            <p
              class="text-xs font-medium uppercase tracking-wider"
              style="color: var(--theme-text-tertiary);"
            >{study.data.company}</p>
            <p class="mt-1 font-medium" style="color: var(--theme-text-primary);">{study.data.title}</p>
          </div>
        </a>
      ))}
    </div>
  )}
</div>
