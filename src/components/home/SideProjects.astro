---
/**
 * SideProjects — single column, matching the work section.
 * Section heading: "Side projects" (lowercase "projects").
 */
import { getCollection } from "astro:content";
import CaseStudyCard from "../work/CaseStudyCard.astro";

const sideProjects = (await getCollection("work", ({ data }) => !data.draft && data.employer === "side-project"))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

{sideProjects.length > 0 && (
  <section
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-5);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div style="margin-bottom: var(--theme-space-5);">
      <h2
        class="font-heading"
        style="
          color: var(--theme-text-primary);
          font-weight: 500;
          letter-spacing: var(--theme-tracking-tight);
          line-height: var(--theme-leading-tight);
          font-size: var(--theme-text-3xl);
        "
      >
        Side projects
      </h2>
    </div>

    <div
      style="
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
      "
    >
      {sideProjects.map((study) => (
        <CaseStudyCard study={study} />
      ))}
    </div>
  </section>
)}
