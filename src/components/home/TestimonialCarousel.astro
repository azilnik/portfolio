---
/**
 * TestimonialCarousel — left-anchored quote rail, shell-bounded.
 *
 * The rail lives inside the same content shell as the Hero and Work
 * sections so the first quote's left edge lines up with everything
 * else on the page (the site's vertical reading axis). Cards cap at
 * 40rem so the quote stays at a readable measure on every viewport.
 * Snap-start pins each card to the rail's left edge on release. A
 * soft fade on the rail's right edge feathers the next card so the
 * "more available" signal reads as deliberate, not as a crop.
 *
 * No JavaScript, no autoplay, no hover transforms.
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const testimonials = await getCollection("testimonials");

/**
 * Extract initials from a full name (e.g. "Kevin Scott" → "KS").
 * Used as a fallback when no avatar image is provided.
 */
function getInitials(name: string): string {
  return name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .toUpperCase()
    .slice(0, 2);
}
---

<section
  class="mx-auto px-6"
  style="
    max-width: var(--theme-content-width);
    padding-top: var(--theme-space-5);
    padding-bottom: var(--theme-space-5);
  "
>
  {/* Shell-bounded scroll rail. The wrapper sits inside the page's
      content shell (matching Hero, Work, etc.), and `-mx-6` extends
      the rail back to the shell's edges so cards can scroll past the
      visible right edge of the section. The first card's left aligns
      with `padding-inline: 1.5rem`, matching the section's px-6 — so
      the rail anchors to the same vertical axis as everything above
      and below. The mask fades the rail's right edge so the peeked
      neighbor feathers out gracefully instead of getting hard-cropped. */}
  <div
    class="testimonial-rail hide-scrollbar -mx-6 flex snap-x snap-mandatory items-stretch overflow-x-auto overflow-y-hidden pb-4 animate-in"
    style="
      gap: clamp(2rem, 6vw, 6rem);
      padding-inline: 1.5rem;
      scroll-padding-inline-start: 1.5rem;
      scroll-padding-inline-end: 1.5rem;
      overscroll-behavior-x: contain;
    "
  >
    {testimonials.map((t) => (
      <blockquote
        class="flex flex-none flex-col py-8 snap-start"
        style="width: min(40rem, calc(100vw - 3rem));"
      >
        <p
          style="
            color: var(--theme-text-secondary);
            font-size: var(--theme-text-lg);
            line-height: var(--theme-lh-lg);
          "
        >"{t.data.quote}"</p>

        {t.data.linkedinUrl ? (
          <a
            href={t.data.linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto pt-6 flex items-center gap-4"
            data-goatcounter-click={`linkedin-${t.data.authorName.toLowerCase().replace(/\s+/g, "-")}`}
          >
            {t.data.avatar ? (
              <Image
                src={t.data.avatar}
                alt={t.data.authorName}
                width={48}
                height={48}
                class="h-12 w-12 shrink-0 rounded-full object-cover"
              />
            ) : (
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
                style="background-color: var(--theme-accent);"
              >
                {getInitials(t.data.authorName)}
              </div>
            )}
            <div>
              <p class="font-semibold" style="color: var(--theme-text-primary);">{t.data.authorName}</p>
              <p class="text-sm" style="color: var(--theme-text-secondary);">{t.data.authorTitle}</p>
            </div>
          </a>
        ) : (
          <footer class="mt-auto pt-6 flex items-center gap-4">
            {t.data.avatar ? (
              <Image
                src={t.data.avatar}
                alt={t.data.authorName}
                width={48}
                height={48}
                class="h-12 w-12 shrink-0 rounded-full object-cover"
              />
            ) : (
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
                style="background-color: var(--theme-accent);"
              >
                {getInitials(t.data.authorName)}
              </div>
            )}
            <div>
              <p class="font-semibold" style="color: var(--theme-text-primary);">{t.data.authorName}</p>
              <p class="text-sm" style="color: var(--theme-text-secondary);">{t.data.authorTitle}</p>
            </div>
          </footer>
        )}
      </blockquote>
    ))}
  </div>
</section>

<style>
  /* Edge fade on the rail. The right edge feathers wider so the peeked
     next quote trails off gracefully. The left edge feathers narrowly
     across the section's px-6 gutter (1.5rem) — sized to land entirely
     OUTSIDE the inner content column. The focus card's left edge sits
     at exactly that 1.5rem mark, so at rest it's fully visible and
     anchored to the page's reading axis; only when scrolling does the
     previous card's tail slide into the fade region and feather out
     cleanly instead of clipping against a hard line. */
  .testimonial-rail {
    --rail-fade-end: clamp(2rem, 5vw, 6rem);
    --rail-fade-start: 1.5rem;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 var(--rail-fade-start),
      #000 calc(100% - var(--rail-fade-end)),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 var(--rail-fade-start),
      #000 calc(100% - var(--rail-fade-end)),
      transparent 100%
    );
  }
</style>
