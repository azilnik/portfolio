---
/**
 * TestimonialCarousel — replaced with a 2-column blockquote grid.
 *
 * Warm Signal: green left border, no background, no JS. Simple grid
 * of pull-quotes with avatar images.
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const testimonials = await getCollection("testimonials");
---

{testimonials.length > 0 && (
  <section
    style="
      padding-top: var(--theme-space-6);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div
      class="mx-auto px-6"
      style="max-width: var(--theme-content-width);"
    >
      <p
        class="font-heading text-sm font-semibold uppercase"
        style="
          color: var(--theme-text-tertiary);
          letter-spacing: var(--theme-tracking-wider);
          margin-bottom: var(--theme-space-4);
        "
      >
        What colleagues say
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2" style="gap: var(--theme-space-4);">
        {testimonials.map((t) => (
          <blockquote
            class="animate-in"
            style="border-left: 3px solid #2A5F4F; padding: 1.5rem 0 1.5rem 1.5rem;"
          >
            <p
              style="
                color: var(--theme-text-secondary);
                font-size: var(--theme-text-base);
                line-height: var(--theme-leading-relaxed);
              "
            >
              "{t.data.quote}"
            </p>

            <footer class="flex items-center gap-3" style="margin-top: 1rem;">
              {t.data.avatar && (
                <Image
                  src={t.data.avatar}
                  alt={t.data.authorName}
                  width={40}
                  height={40}
                  class="h-10 w-10 shrink-0 object-cover"
                  style="border-radius: 9999px;"
                />
              )}
              <div>
                {t.data.linkedinUrl ? (
                  <a
                    href={t.data.linkedinUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-semibold text-sm transition-colors"
                    style="color: var(--theme-text-primary);"
                    data-goatcounter-click={`linkedin-${t.data.authorName.toLowerCase().replace(/\s+/g, "-")}`}
                  >
                    {t.data.authorName}
                  </a>
                ) : (
                  <p class="font-semibold text-sm" style="color: var(--theme-text-primary);">{t.data.authorName}</p>
                )}
                <p class="text-xs" style="color: var(--theme-text-tertiary);">{t.data.authorTitle}</p>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>
)}
