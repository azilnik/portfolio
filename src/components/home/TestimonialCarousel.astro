---
/**
 * TestimonialCarousel — full-bleed CSS scroll-snap quote rail.
 *
 * Pure CSS pattern: a horizontal flex container with `scroll-snap-type:
 * x mandatory` and dynamic `padding-inline` so the active card lands at
 * viewport center while neighbors peek over the screen edges. Native
 * touch swipe, shift+wheel, and the (hidden) scrollbar all just work.
 * No JavaScript, no autoplay, no hover transforms.
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const testimonials = await getCollection("testimonials");

/**
 * Extract initials from a full name (e.g. "Kevin Scott" → "KS").
 * Used as a fallback when no avatar image is provided.
 */
function getInitials(name: string): string {
  return name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .toUpperCase()
    .slice(0, 2);
}
---

<section
  style="
    padding-top: var(--theme-space-7);
    padding-bottom: var(--theme-space-7);
  "
>
  <div
    class="hide-scrollbar flex snap-x snap-mandatory items-stretch gap-6 overflow-x-auto overflow-y-hidden pb-4 animate-in"
    style="
      padding-inline: max(1.5rem, calc(50vw - 24rem));
      scroll-padding-inline: max(1.5rem, calc(50vw - 24rem));
      overscroll-behavior-x: contain;
    "
  >
    {testimonials.map((t) => (
      <blockquote
        class="flex flex-none flex-col p-8"
        style="width: clamp(280px, 80vw, 48rem); scroll-snap-align: center;"
      >
        <p
          class="leading-relaxed"
          style="
            color: var(--theme-text-secondary);
            font-size: var(--theme-text-lg);
          "
        >"{t.data.quote}"</p>

        {t.data.linkedinUrl ? (
          <a
            href={t.data.linkedinUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto pt-6 flex items-center gap-3"
            data-goatcounter-click={`linkedin-${t.data.authorName.toLowerCase().replace(/\s+/g, "-")}`}
          >
            {t.data.avatar ? (
              <Image
                src={t.data.avatar}
                alt={t.data.authorName}
                width={48}
                height={48}
                class="h-12 w-12 shrink-0 rounded-full object-cover"
              />
            ) : (
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
                style="background-color: var(--theme-accent);"
              >
                {getInitials(t.data.authorName)}
              </div>
            )}
            <div>
              <p class="font-semibold" style="color: var(--theme-text-primary);">{t.data.authorName}</p>
              <p class="text-sm" style="color: var(--theme-text-secondary);">{t.data.authorTitle}</p>
            </div>
          </a>
        ) : (
          <footer class="mt-auto pt-6 flex items-center gap-3">
            {t.data.avatar ? (
              <Image
                src={t.data.avatar}
                alt={t.data.authorName}
                width={48}
                height={48}
                class="h-12 w-12 shrink-0 rounded-full object-cover"
              />
            ) : (
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
                style="background-color: var(--theme-accent);"
              >
                {getInitials(t.data.authorName)}
              </div>
            )}
            <div>
              <p class="font-semibold" style="color: var(--theme-text-primary);">{t.data.authorName}</p>
              <p class="text-sm" style="color: var(--theme-text-secondary);">{t.data.authorTitle}</p>
            </div>
          </footer>
        )}
      </blockquote>
    ))}
  </div>
</section>
