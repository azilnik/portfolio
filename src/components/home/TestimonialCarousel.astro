---
/**
 * TestimonialCarousel — static 2-column grid of quotes.
 * Dark Gravity theme. No carousel JS, no dots, no auto-rotation.
 */
import { getCollection } from "astro:content";

const testimonials = await getCollection("testimonials");
---

<section
  style="
    padding-top: var(--theme-space-7);
    padding-bottom: var(--theme-space-7);
  "
>
  <div
    class="mx-auto px-6"
    style="max-width: 64rem;"
  >
    <p
      class="text-xs font-semibold uppercase animate-in"
      style="
        color: #6B6560;
        letter-spacing: var(--theme-tracking-wider);
        margin-bottom: var(--theme-space-5);
      "
    >
      What colleagues say
    </p>

    <div
      class="grid grid-cols-1 md:grid-cols-2 animate-in"
      style="gap: var(--theme-space-4); --delay: 100ms;"
    >
      {testimonials.map((t) => (
        <blockquote
          style="background: #161514; border-left: 3px solid #D4A853; padding: 2rem;"
        >
          <p
            class="leading-relaxed"
            style="
              color: #9B9590;
              font-size: var(--theme-text-lg);
            "
          >"{t.data.quote}"</p>

          {t.data.linkedinUrl ? (
            <a href={t.data.linkedinUrl} target="_blank" rel="noopener noreferrer" class="mt-6 block group"
              data-goatcounter-click={`linkedin-${t.data.authorName.toLowerCase().replace(/\s+/g, "-")}`}>
              <p class="font-semibold transition-colors" style="color: #E8E4DF;">{t.data.authorName}</p>
              <p class="text-sm" style="color: #6B6560;">{t.data.authorTitle}</p>
            </a>
          ) : (
            <footer class="mt-6">
              <p class="font-semibold" style="color: #E8E4DF;">{t.data.authorName}</p>
              <p class="text-sm" style="color: #6B6560;">{t.data.authorTitle}</p>
            </footer>
          )}
        </blockquote>
      ))}
    </div>
  </div>
</section>
