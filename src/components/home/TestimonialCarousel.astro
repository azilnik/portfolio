---
/**
 * TestimonialCarousel — horizontal scroll carousel of quotes.
 *
 * Uses CSS scroll-snap for smooth, snappy scrolling and vanilla JS for
 * dot indicators and optional auto-rotation. No library dependencies.
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const testimonials = await getCollection("testimonials");

/**
 * Extract initials from a full name (e.g. "Kevin Scott" → "KS").
 * Used as a fallback when no avatar image is provided.
 */
function getInitials(name: string): string {
  return name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .toUpperCase()
    .slice(0, 2);
}
---

<section class="py-20" style="background-color: var(--theme-bg);">
  <div class="mx-auto max-w-6xl px-6">
    <h2
      class="mb-12 text-center font-heading text-2xl font-bold"
      style="color: var(--theme-text-primary);"
    >
      What people say
    </h2>

    {/* Scrollable container — snap to each testimonial card */}
    <div
      id="testimonial-track"
      class="hide-scrollbar flex snap-x snap-proximity gap-6 overflow-x-auto pb-4"
    >
      {testimonials.map((t) => (
        <blockquote
          class="flex-none w-full snap-center rounded-2xl p-8 shadow-sm sm:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]"
          style="background-color: var(--theme-surface);"
        >
          <p class="text-lg leading-relaxed" style="color: var(--theme-text-secondary);">"{t.data.quote}"</p>
          {/* Wrap the entire footer (avatar + name + title) in one link when LinkedIn is available */}
          {t.data.linkedinUrl ? (
            <a href={t.data.linkedinUrl} target="_blank" rel="noopener noreferrer" class="mt-6 flex items-center gap-3 group"
              data-goatcounter-click={`linkedin-${t.data.authorName.toLowerCase().replace(/\s+/g, "-")}`}>
              {t.data.avatar ? (
                <Image
                  src={t.data.avatar}
                  alt={t.data.authorName}
                  width={48}
                  height={48}
                  class="h-12 w-12 shrink-0 rounded-full object-cover"
                />
              ) : (
                <div
                  class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
                  style="background-color: var(--theme-accent);"
                >
                  {getInitials(t.data.authorName)}
                </div>
              )}
              <div>
                <p class="font-semibold transition-colors" style="color: var(--theme-text-primary);">{t.data.authorName}</p>
                <p class="text-sm" style="color: var(--theme-text-secondary);">{t.data.authorTitle}</p>
              </div>
            </a>
          ) : (
            <footer class="mt-6 flex items-center gap-3">
              {t.data.avatar ? (
                <Image
                  src={t.data.avatar}
                  alt={t.data.authorName}
                  width={48}
                  height={48}
                  class="h-12 w-12 shrink-0 rounded-full object-cover"
                />
              ) : (
                <div
                  class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white"
                  style="background-color: var(--theme-accent);"
                >
                  {getInitials(t.data.authorName)}
                </div>
              )}
              <div>
                <p class="font-semibold" style="color: var(--theme-text-primary);">{t.data.authorName}</p>
                <p class="text-sm" style="color: var(--theme-text-secondary);">{t.data.authorTitle}</p>
              </div>
            </footer>
          )}
        </blockquote>
      ))}
    </div>

    {/* Dot indicators — use inline styles so JS can swap colors via CSS variables */}
    <div id="testimonial-dots" class="mt-6 flex justify-center gap-2">
      {testimonials.map((_, i) => (
        <button
          class="testimonial-dot h-2 w-2 rounded-full transition-colors"
          style="background-color: var(--theme-border-strong);"
          data-index={i}
          aria-label={`Go to testimonial ${i + 1}`}
        />
      ))}
    </div>
  </div>
</section>

<script>
  /**
   * Testimonial carousel logic — dot indicators + auto-rotation.
   *
   * Uses IntersectionObserver to detect which card is currently visible,
   * then updates the active dot. Auto-advances every 5 seconds, but only
   * when the carousel is visible on screen (to avoid hijacking page scroll).
   *
   * IMPORTANT: We use track.scrollTo() instead of scrollIntoView() so that
   * scrolling stays inside the carousel container and never moves the page.
   */
  function initCarousel() {
    const track = document.getElementById("testimonial-track");
    const dots = document.querySelectorAll(".testimonial-dot");
    if (!track || dots.length === 0) return;

    const cards = track.querySelectorAll("blockquote");
    let currentIndex = 0;
    let autoplayInterval: ReturnType<typeof setInterval>;
    let isVisible = false;

    // Scroll to a specific card by index — only moves the carousel, not the page.
    function scrollToCard(index: number) {
      const card = cards[index] as HTMLElement;
      if (!card) return;
      track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: "smooth" });
    }

    /**
     * Update which dot is "active" (highlighted).
     * Uses inline style manipulation instead of Tailwind classes so that
     * the dot color adapts to the active theme's CSS variables.
     */
    function setActiveDot(index: number) {
      const accentColor = getComputedStyle(document.documentElement).getPropertyValue("--theme-accent").trim();
      const inactiveColor = getComputedStyle(document.documentElement).getPropertyValue("--theme-border-strong").trim();
      dots.forEach((dot, i) => {
        (dot as HTMLElement).style.backgroundColor = i === index ? accentColor : inactiveColor;
      });
      currentIndex = index;
    }

    // Watch which card scrolls into view within the track.
    const cardObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = Array.from(cards).indexOf(entry.target as HTMLElement);
            if (index >= 0) setActiveDot(index);
          }
        });
      },
      { root: track, threshold: 0.6 }
    );

    cards.forEach((card) => cardObserver.observe(card));

    // Track whether the carousel section is visible on the page.
    // Auto-rotation only runs when the user can actually see it.
    const sectionObserver = new IntersectionObserver(
      ([entry]) => { isVisible = entry.isIntersecting; },
      { threshold: 0.3 }
    );
    sectionObserver.observe(track.closest("section")!);

    // Click a dot to scroll to that card.
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const index = Number((dot as HTMLElement).dataset.index);
        scrollToCard(index);
      });
    });

    // Auto-rotate every 5 seconds, pause on hover or when off-screen.
    function startAutoplay() {
      autoplayInterval = setInterval(() => {
        if (!isVisible) return;
        const next = (currentIndex + 1) % cards.length;
        scrollToCard(next);
      }, 5000);
    }

    track.addEventListener("mouseenter", () => clearInterval(autoplayInterval));
    track.addEventListener("mouseleave", startAutoplay);
    startAutoplay();

    // Set the first dot as active initially.
    setActiveDot(0);
  }

  initCarousel();
  document.addEventListener("astro:after-swap", initCarousel);
</script>
