---
/**
 * TestimonialCarousel — replaced with a single editorial pull-quote.
 *
 * No carousel, no dots, no auto-rotation. One large italic serif quote,
 * centered, with the author below. Simple and editorial.
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const testimonials = await getCollection("testimonials");
const featured = testimonials[0];
---

{featured && (
  <section
    style="
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div
      class="mx-auto px-6 text-center animate-in"
      style="max-width: 48rem;"
    >
      <blockquote>
        <p
          class="font-heading italic"
          style="
            color: var(--theme-text-primary);
            font-size: var(--theme-text-3xl);
            line-height: var(--theme-leading-snug);
          "
        >
          "{featured.data.quote}"
        </p>

        {/* Author attribution */}
        <footer class="flex items-center justify-center gap-3" style="margin-top: var(--theme-space-4);">
          {featured.data.avatar && (
            <Image
              src={featured.data.avatar}
              alt={featured.data.authorName}
              width={40}
              height={40}
              class="h-10 w-10 shrink-0 object-cover"
              style="border-radius: 9999px;"
            />
          )}
          <div class="text-left">
            {featured.data.linkedinUrl ? (
              <a
                href={featured.data.linkedinUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="font-semibold text-sm transition-colors"
                style="color: var(--theme-text-primary);"
                data-goatcounter-click={`linkedin-${featured.data.authorName.toLowerCase().replace(/\s+/g, "-")}`}
              >
                {featured.data.authorName}
              </a>
            ) : (
              <p class="font-semibold text-sm" style="color: var(--theme-text-primary);">{featured.data.authorName}</p>
            )}
            <p class="text-xs" style="color: var(--theme-text-tertiary);">{featured.data.authorTitle}</p>
          </div>
        </footer>
      </blockquote>
    </div>
  </section>
)}
