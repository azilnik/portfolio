---
/**
 * TestimonialCarousel — Quiet Warm.
 *
 * Big bold quote, one at a time, scroll-snap horizontal carousel with dot
 * indicators and auto-advance. Monochrome — no green, no serif. Avatar
 * shown beneath the quote. Big-and-bold framing borrowed from Editorial
 * Tension; carousel mechanic carried over from the Warm Signal prototype.
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const testimonials = await getCollection("testimonials");
---

{testimonials.length > 0 && (
  <section
    style="
      padding-top: 4rem;
      padding-bottom: 4rem;
    "
  >
    <div
      class="mx-auto px-6"
      style="max-width: var(--theme-content-width);"
    >
      <p
        class="font-heading"
        style="
          color: var(--theme-text-tertiary);
          font-size: 0.75rem;
          font-weight: 600;
          letter-spacing: 0.08em;
          text-transform: uppercase;
          margin-bottom: 2rem;
        "
      >
        What colleagues say
      </p>

      <div
        class="qw-testimonial-track"
        role="region"
        aria-roledescription="carousel"
        aria-label="Colleague testimonials"
      >
        <div class="qw-testimonial-rail" data-qw-rail>
          {testimonials.map((t, i) => (
            <article
              class="qw-testimonial-slide"
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} of ${testimonials.length}`}
              data-index={i}
              tabindex="0"
            >
              <blockquote class="qw-testimonial-quote">
                <p class="qw-testimonial-text">
                  &ldquo;{t.data.quote}&rdquo;
                </p>
                <footer class="qw-testimonial-footer">
                  {t.data.avatar && (
                    <Image
                      src={t.data.avatar}
                      alt={t.data.authorName}
                      width={44}
                      height={44}
                      class="qw-testimonial-avatar"
                    />
                  )}
                  <div>
                    {t.data.linkedinUrl ? (
                      <a
                        href={t.data.linkedinUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="qw-testimonial-author"
                        data-goatcounter-click={`linkedin-${t.data.authorName.toLowerCase().replace(/\s+/g, "-")}`}
                      >
                        {t.data.authorName}
                      </a>
                    ) : (
                      <p class="qw-testimonial-author">{t.data.authorName}</p>
                    )}
                    <p class="qw-testimonial-title">{t.data.authorTitle}</p>
                  </div>
                </footer>
              </blockquote>
            </article>
          ))}
        </div>

        <div class="qw-testimonial-dots" role="tablist" aria-label="Choose a testimonial">
          {testimonials.map((_, i) => (
            <button
              type="button"
              class="qw-testimonial-dot"
              data-qw-dot
              data-target={i}
              role="tab"
              aria-label={`Show testimonial ${i + 1}`}
              aria-selected={i === 0}
            />
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .qw-testimonial-track {
    position: relative;
  }

  .qw-testimonial-rail {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 1.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .qw-testimonial-rail::-webkit-scrollbar {
    display: none;
  }

  .qw-testimonial-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    outline: none;
  }

  .qw-testimonial-quote {
    max-width: 52rem;
    padding: 0;
  }

  .qw-testimonial-text {
    color: var(--theme-text-primary);
    font-size: clamp(1.25rem, 1rem + 1.4vw, 1.875rem);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.015em;
  }

  .qw-testimonial-footer {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--theme-border);
  }

  .qw-testimonial-avatar {
    height: 44px;
    width: 44px;
    flex-shrink: 0;
    object-fit: cover;
    border-radius: 9999px;
  }

  .qw-testimonial-author {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--theme-text-primary);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  a.qw-testimonial-author:hover {
    opacity: 0.7;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .qw-testimonial-title {
    font-size: 0.8125rem;
    color: var(--theme-text-tertiary);
    margin-top: 0.125rem;
  }

  .qw-testimonial-dots {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-start;
    margin-top: 2rem;
  }

  .qw-testimonial-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--theme-border);
    border: 0;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .qw-testimonial-dot[aria-selected="true"] {
    background: var(--theme-text-primary);
    transform: scale(1.4);
  }
  .qw-testimonial-dot:focus-visible {
    outline: 2px solid var(--theme-text-primary);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .qw-testimonial-rail { scroll-behavior: auto; }
  }
</style>

<script>
  const rail = document.querySelector<HTMLElement>("[data-qw-rail]");
  const dots = document.querySelectorAll<HTMLButtonElement>("[data-qw-dot]");
  if (rail && dots.length) {
    const slides = rail.querySelectorAll<HTMLElement>(".qw-testimonial-slide");
    const total = slides.length;
    let active = 0;
    let timer: number | null = null;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const setActive = (index: number) => {
      active = ((index % total) + total) % total;
      dots.forEach((d, i) => d.setAttribute("aria-selected", i === active ? "true" : "false"));
    };

    const goTo = (index: number) => {
      const target = slides[((index % total) + total) % total];
      if (!target) return;
      target.scrollIntoView({ behavior: "smooth", inline: "start", block: "nearest" });
      setActive(index);
    };

    dots.forEach((d) => {
      d.addEventListener("click", () => {
        const i = Number(d.dataset.target ?? "0");
        goTo(i);
        restart();
      });
    });

    rail.addEventListener("scroll", () => {
      const railRect = rail.getBoundingClientRect();
      let closest = 0;
      let closestDelta = Infinity;
      slides.forEach((s, i) => {
        const delta = Math.abs(s.getBoundingClientRect().left - railRect.left);
        if (delta < closestDelta) {
          closestDelta = delta;
          closest = i;
        }
      });
      setActive(closest);
    });

    const start = () => {
      if (reduced || total < 2) return;
      timer = window.setInterval(() => goTo(active + 1), 7000);
    };
    const stop = () => {
      if (timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
    };
    const restart = () => { stop(); start(); };

    rail.addEventListener("mouseenter", stop);
    rail.addEventListener("mouseleave", start);
    rail.addEventListener("focusin", stop);
    rail.addEventListener("focusout", start);

    start();
  }
</script>
