---
/**
 * WorkSection — featured case studies on the homepage.
 *
 * Shows the 3 featured case studies as cards, sorted by sortOrder.
 * Previously this section grouped case studies under employer blocks,
 * but with 3 focused case studies (including a side project), a flat
 * list of cards is cleaner and gives equal weight to each piece.
 */
import { getCollection } from "astro:content";
import CaseStudyCard from "../work/CaseStudyCard.astro";

// Fetch all non-draft case studies, sorted by sortOrder.
const allWork = (await getCollection("work", ({ data }) => !data.draft))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section id="work" class="mx-auto max-w-6xl px-6 py-20">
  <h2
    class="mb-4 font-heading text-3xl font-bold md:text-4xl"
    style="color: var(--theme-text-primary);"
  >
    Featured work
  </h2>
  <p class="mb-12 text-lg" style="color: var(--theme-text-secondary);">
    Three projects that show how I think, lead, and build.
  </p>

  {/* Case study grid — responsive, 1 col on mobile, 2 on tablet, 3 on desktop */}
  {allWork.length > 0 ? (
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {allWork.map((study) => (
        <CaseStudyCard study={study} />
      ))}
    </div>
  ) : (
    <p style="color: var(--theme-text-tertiary);">Case studies coming soon.</p>
  )}
</section>
