---
/**
 * Hero — the top section of the homepage.
 *
 * Shows a circular avatar, heading, bio paragraphs, and CTA buttons.
 * The outer wrapper carries a full-bleed mesh gradient background
 * (defined in themes.css as --theme-bg-gradient).
 */
import { Image } from "astro:assets";
import avatarImage from "../../assets/images/avatar.jpg";
---

{/* Full-width gradient wrapper — the mesh gradient spans edge-to-edge */}
<div style="background-image: var(--theme-bg-gradient, none);">
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-16 text-center">
    {/* Circular avatar */}
    <div class="mb-8 flex justify-center">
      <Image
        src={avatarImage}
        alt="Ari Zilnik"
        width={120}
        height={120}
        class="rounded-full"
        loading="eager"
      />
    </div>

    {/* Heading */}
    <h1
      class="font-heading text-4xl font-bold md:text-5xl"
      style="color: var(--theme-text-primary);"
    >
      Hey, I'm Ari Zilnik.
    </h1>

    {/* Bio — short, scannable lines with bold highlights on key phrases */}
    <div class="mt-6 space-y-4 text-lg leading-relaxed" style="color: var(--theme-text-secondary);">
      <p>
        I'm a <span class="font-semibold" style="color: var(--theme-text-primary);">hands-on design leader</span> with
        13 years of experience.
      </p>
      <p>
        I fix up vintage audio equipment and other gadgets for fun.
      </p>
      <p>
        I am currently <span class="font-semibold" style="color: var(--theme-text-primary);">Head of Design at Join</span>.
      </p>
    </div>

    {/* CTA buttons */}
    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="#"
        class="inline-flex items-center gap-2 rounded-full px-8 py-3 text-sm font-semibold transition-colors"
        style="background-color: var(--theme-text-primary); color: var(--theme-bg);"
        data-goatcounter-click="resume-hero"
      >
        Resume
      </a>
      <a
        href="mailto:ari@ari.design"
        class="inline-flex items-center gap-2 rounded-full border px-8 py-3 text-sm font-semibold transition-colors"
        style="border-color: var(--theme-border-strong); color: var(--theme-text-primary);"
        data-goatcounter-click="contact-hero"
      >
        Get in touch
      </a>
    </div>

    {/* Scroll anchor link */}
    <a
      href="#work"
      class="mt-16 inline-flex items-center gap-2 text-sm font-medium transition-colors"
      style="color: var(--theme-text-tertiary);"
    >
      See my work
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>
</div>
