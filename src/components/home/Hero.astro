---
/**
 * Hero — the top section of the homepage.
 *
 * Editorial tension: enormous serif name, no avatar, left-aligned.
 * The typography IS the design. Let the name do the work.
 */
---

<div style="background-image: var(--theme-bg-gradient, none);">
  <section
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-8);
      padding-bottom: var(--theme-space-7);
    "
  >
    {/* Name — enormous, serif, tight tracking */}
    <h1
      class="font-heading animate-in"
      style="
        color: var(--theme-text-primary);
        font-weight: var(--theme-weight-heading);
        letter-spacing: -0.03em;
        line-height: 1.0;
        font-size: var(--theme-text-hero);
        --delay: 0ms;
      "
    >
      Ari Zilnik
    </h1>

    {/* Bio paragraph */}
    <div
      class="font-sans animate-in"
      style="
        color: var(--theme-text-secondary);
        font-size: var(--theme-text-xl);
        line-height: var(--theme-leading-relaxed);
        margin-top: var(--theme-space-5);
        max-width: 40rem;
        --delay: 80ms;
      "
    >
      <p>
        I run design at <a href="https://join.build" target="_blank" rel="noopener noreferrer" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Join</a>, where construction companies use our tools to make faster, better-informed decisions. Before that I was the founding designer at Blockdaemon, design lead at Gradle, and design lead at Jet.com through Walmart's acquisition.
      </p>
    </div>

    {/* CTAs */}
    <div class="flex gap-3 animate-in" style="margin-top: var(--theme-space-5); --delay: 160ms;">
      <a
        href="mailto:ari@zilnik.com"
        class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold transition-colors"
        style="background-color: var(--theme-text-primary); color: var(--theme-bg);"
        data-goatcounter-click="contact-hero"
      >
        Get in touch
      </a>
      <a
        href="#work"
        class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold transition-colors"
        style="border: 1px solid var(--theme-border-strong); color: var(--theme-text-secondary);"
      >
        See my work
      </a>
    </div>
  </section>
</div>
