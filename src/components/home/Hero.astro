---
/**
 * Hero — the top section of the homepage.
 *
 * Shows a circular avatar, heading, bio paragraphs, and CTA buttons.
 * The outer wrapper carries the full-bleed mesh gradient background
 * (defined in themes.css as --theme-bg-gradient).
 *
 * Copy targets senior IC / player-coach roles at premium product
 * companies. It leads with what Ari does for businesses, not tenure.
 *
 * Spacing sits on the baseline grid (--theme-space-*) so the hero feels
 * harmonious with the rest of the page and doesn't dwarf the sections
 * that follow it.
 */
import { Image } from "astro:assets";
import avatarImage from "../../assets/images/avatar.jpg";
---

{/* Full-width gradient wrapper — the mesh gradient spans edge-to-edge */}
<div style="background-image: var(--theme-bg-gradient, none);">
  <section
    class="mx-auto max-w-2xl px-6 text-center"
    style="
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-6);
    "
  >
    {/* Circular avatar — slightly smaller so it doesn't compete with
        the display title below it. */}
    <div
      class="flex justify-center"
      style="margin-bottom: var(--theme-space-4);"
    >
      <Image
        src={avatarImage}
        alt="Ari Zilnik"
        width={96}
        height={96}
        class="rounded-full"
        loading="eager"
      />
    </div>

    {/* Display heading — uses the fluid clamp() scale from themes.css
        so it scales from ~48px on mobile to ~64px on desktop without
        a breakpoint jump. */}
    <h1
      class="font-heading"
      style="
        color: var(--theme-text-primary);
        font-weight: var(--theme-weight-heading);
        letter-spacing: var(--theme-tracking-tight);
        line-height: var(--theme-leading-tight);
        font-size: var(--theme-text-6xl);
      "
    >
      Hey, I'm Ari Zilnik.
    </h1>

    {/* Bio — leads with what Ari does for businesses, not years of experience */}
    <div
      class="font-sans"
      style="
        color: var(--theme-text-secondary);
        font-size: var(--theme-text-xl);
        line-height: var(--theme-leading-relaxed);
        margin-top: var(--theme-space-4);
      "
    >
      <p>
        I'm a <span class="font-semibold" style="color: var(--theme-text-primary);">design leader who ships products that move business metrics</span>.
        From AI-powered construction tools to crypto infrastructure used by Goldman Sachs.
      </p>
      <p style="margin-top: var(--theme-space-3);">
        I build teams, run research, and stay close to the work.
        Currently <span class="font-semibold" style="color: var(--theme-text-primary);">Head of Design at Join</span>.
      </p>
    </div>

    {/* CTA buttons */}
    <div
      class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center"
      style="margin-top: var(--theme-space-5);"
    >
      <a
        href="mailto:ari@ari.design"
        class="inline-flex items-center gap-2 rounded-full px-7 py-3 text-sm font-semibold transition-colors"
        style="background-color: var(--theme-text-primary); color: var(--theme-bg);"
        data-goatcounter-click="contact-hero"
      >
        Get in touch
      </a>
      <a
        href="/work"
        class="inline-flex items-center gap-2 rounded-full border px-7 py-3 text-sm font-semibold transition-colors"
        style="border-color: var(--theme-border-strong); color: var(--theme-text-primary);"
        data-goatcounter-click="work-hero"
      >
        See my work
      </a>
    </div>

    {/* Scroll anchor link */}
    <a
      href="#work"
      class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
      style="
        color: var(--theme-text-tertiary);
        margin-top: var(--theme-space-6);
      "
    >
      Featured projects
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </section>
</div>
