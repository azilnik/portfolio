---
/**
 * Hero — the top section of the homepage.
 *
 * Shows a circular avatar, heading, bio paragraphs, and CTA buttons.
 * Matches the production ari.design homepage hero layout.
 */
import { Image } from "astro:assets";
import avatarImage from "../../assets/images/avatar.jpg";
---

<section class="mx-auto max-w-3xl px-6 pt-20 pb-16 text-center">
  {/* Circular avatar */}
  <div class="mb-8 flex justify-center">
    <Image
      src={avatarImage}
      alt="Ari Zilnik"
      width={120}
      height={120}
      class="rounded-full"
      loading="eager"
    />
  </div>

  {/* Heading */}
  <h1 class="font-heading text-4xl font-bold text-gray-900 md:text-5xl">
    Hey, I'm Ari Zilnik.
  </h1>

  {/* Bio — short, scannable lines with bold highlights on key phrases */}
  <div class="mt-6 space-y-4 text-lg leading-relaxed text-gray-500">
    <p>
      I'm a <span class="font-semibold text-gray-900">hands-on design leader</span> with
      13 years of experience.
    </p>
    <p>
      I fix up vintage audio equipment and other gadgets for fun.
    </p>
    <p>
      I am currently <span class="font-semibold text-gray-900">Head of Design at Join</span>.
    </p>
  </div>

  {/* CTA buttons */}
  <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
    <a
      href="#"
      class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-gray-800"
    >
      Resume
    </a>
    <a
      href="mailto:ari@ari.design"
      class="inline-flex items-center gap-2 rounded-full border border-gray-300 px-8 py-3 text-sm font-semibold text-gray-900 transition-colors hover:border-gray-400"
    >
      Get in touch
    </a>
  </div>

  {/* Scroll anchor link */}
  <a
    href="#work"
    class="mt-16 inline-flex items-center gap-2 text-sm font-medium text-gray-400 transition-colors hover:text-gray-600"
  >
    See my work
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>
