---
/**
 * Hero — cinematic centered hero for Dark Gravity theme.
 * No avatar, no gradient background. Centered name + gold line + tagline.
 */
---

<section style="padding-top: 10rem; padding-bottom: 8rem;">
  <div style="max-width: 64rem;" class="mx-auto px-6 text-center">
    <h1 class="font-heading animate-in" style="font-size: var(--theme-text-6xl); font-weight: 700; color: #E8E4DF; letter-spacing: -0.03em; line-height: 1.05;">Ari Zilnik</h1>
    <div class="animate-in" style="--delay: 150ms; margin: 1.5rem auto; height: 2px; width: 80px; background: #D4A853;"></div>
    <p class="animate-in" style="--delay: 250ms; font-size: var(--theme-text-xl); color: #9B9590; line-height: 1.6; max-width: 36rem; margin: 0 auto;">
      Design leader building products for industries that run on expertise, not aesthetics. Construction. Crypto infrastructure. Developer tools.
    </p>
    <div class="flex justify-center gap-4 animate-in" style="--delay: 350ms; margin-top: 2.5rem;">
      <a href="mailto:ari@zilnik.com" class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold" style="background: #D4A853; color: #0D0D0D; border-radius: 4px;" data-goatcounter-click="contact-hero">Get in touch</a>
      <a href="#work" class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold" style="border: 1px solid #2A2825; color: #9B9590; border-radius: 4px;">See my work</a>
    </div>
  </div>
</section>
