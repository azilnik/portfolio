---
/**
 * Hero — business-card format. Name, title, email. Nothing else.
 * Quiet Authority: reduction IS the design choice.
 */
---

<section
  class="mx-auto px-6"
  style="
    max-width: var(--theme-content-width);
    padding-top: 10rem;
    padding-bottom: 8rem;
  "
>
  <h1
    class="font-heading animate-in"
    style="
      font-size: var(--theme-text-6xl);
      font-weight: 500;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--theme-text-primary);
    "
  >
    Ari Zilnik
  </h1>

  <div
    class="animate-in"
    style="
      margin-top: 1.5rem;
      font-size: var(--theme-text-xl);
      color: var(--theme-text-secondary);
      line-height: 1.6;
    "
  >
    <p>Head of Design, Join</p>
    <p style="margin-top: 0.25rem;">Previously Blockdaemon, Gradle, Jet.com</p>
  </div>

  <div class="animate-in" style="margin-top: 2rem;">
    <a
      href="mailto:ari@zilnik.com"
      style="
        color: var(--theme-text-primary);
        text-decoration: underline;
        text-underline-offset: 4px;
      "
      data-goatcounter-click="contact-hero"
    >
      ari@zilnik.com
    </a>
  </div>
</section>
