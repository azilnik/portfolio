---
/**
 * CaseStudyCard — thumbnail + text for homepage and /work listing.
 *
 * Warm Signal: small-caps company name in Fraunces, green title with
 * terracotta hover, 4px radius images with 1px border.
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  study: CollectionEntry<"work">;
  featured?: boolean;
}

const { study, featured = false } = Astro.props;
---

<a
  href={`/work/${study.id}`}
  data-goatcounter-click={`casestudy-click-${study.id}`}
  class="group block animate-in"
>
  {/* Thumbnail */}
  <div class="overflow-hidden" style="border-radius: 4px;">
    <Image
      src={study.data.thumbnail}
      alt={study.data.thumbnailAlt}
      widths={[400, 600, 800]}
      sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
      class="w-full object-cover aspect-[16/10] transition-transform duration-500 group-hover:scale-[1.02]"
      style="border: 1px solid var(--theme-border);"
    />
  </div>

  {/* Text */}
  <div style="padding-top: var(--theme-space-2);">
    <p
      class="text-xs font-semibold uppercase small-caps font-heading"
      style="
        color: var(--theme-text-tertiary);
        letter-spacing: var(--theme-tracking-wider);
      "
    >
      {study.data.company}
    </p>

    <h3
      class="font-heading case-study-title"
      style="
        color: #2A5F4F;
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.3;
        font-size: var(--theme-text-lg);
        margin-top: 0.25rem;
        transition: color 0.3s ease;
      "
    >
      {study.data.title}
    </h3>

    <p
      class="leading-relaxed line-clamp-2"
      style="
        color: var(--theme-text-secondary);
        font-size: var(--theme-text-sm);
        margin-top: var(--theme-space-1);
      "
    >
      {study.data.description}
    </p>
  </div>
</a>

<style>
  .group:hover .case-study-title {
    color: #C65D3E !important;
  }
</style>
