---
/**
 * CaseStudyCard — full-width image, text below. No card container,
 * no border, no shadow. All cards treated equally.
 * Hover: subtle opacity change on the image, no scale.
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  study: CollectionEntry<"work">;
}

const { study } = Astro.props;
---

<a
  href={`/work/${study.id}`}
  data-goatcounter-click={`casestudy-click-${study.id}`}
  class="group block animate-in"
>
  {/* Thumbnail — full width, no border-radius */}
  <div class="overflow-hidden">
    <Image
      src={study.data.thumbnail}
      alt={study.data.thumbnailAlt}
      widths={[600, 900, 1200]}
      sizes="(min-width: 1024px) 72rem, 100vw"
      class="w-full object-cover aspect-[16/10] transition-opacity duration-500 group-hover:opacity-90"
    />
  </div>

  {/* Text — sits below the image */}
  <div style="padding-top: var(--theme-space-3);">
    <p
      class="text-xs uppercase"
      style="
        color: var(--theme-text-tertiary);
        letter-spacing: var(--theme-tracking-wider);
        font-weight: 400;
      "
    >
      {study.data.company}
    </p>

    <h3
      class="font-heading"
      style="
        color: var(--theme-text-primary);
        font-weight: 500;
        letter-spacing: var(--theme-tracking-tight);
        line-height: var(--theme-leading-snug);
        font-size: var(--theme-text-xl);
        margin-top: 0.25rem;
      "
    >
      {study.data.title}
    </h3>

    <p
      style="
        color: var(--theme-text-secondary);
        font-size: var(--theme-text-sm);
        margin-top: var(--theme-space-1);
        line-height: var(--theme-leading-relaxed);
      "
    >
      {study.data.description}
    </p>
  </div>
</a>
