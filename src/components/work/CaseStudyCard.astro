---
/**
 * CaseStudyCard — thumbnail + text for homepage and /work listing.
 *
 * No card container or border. The image IS the card. Text sits
 * directly below. The thumbnail carries a layered Josh-Comeau
 * shadow so it lifts off the warm sand surface; on hover the
 * shadow steps up to "high" and the image scales subtly.
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  study: CollectionEntry<"work">;
  featured?: boolean;
}

const { study, featured = false } = Astro.props;
---

<a
  href={`/work/${study.id}`}
  data-goatcounter-click={`casestudy-click-${study.id}`}
  class:list={[
    "group block animate-in",
    featured ? "grid grid-cols-1 lg:grid-cols-2 lg:items-center gap-6" : "",
  ]}
>
  {/* Thumbnail */}
  <div
    class="case-study-card-thumb overflow-hidden"
    style="border-radius: var(--theme-radius-lg);"
  >
    <Image
      src={study.data.thumbnail}
      alt={study.data.thumbnailAlt}
      widths={featured ? [600, 900, 1200] : [400, 600, 800]}
      sizes={featured
        ? "(min-width: 1024px) 50vw, 100vw"
        : "(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
      }
      class="w-full aspect-[16/10] object-cover"
    />
  </div>

  {/* Text — sits directly below the image, no container */}
  <div style={`padding-top: ${featured ? "0" : "var(--theme-space-2)"};`}>
    <p
      class="text-xs font-semibold uppercase"
      style="
        color: var(--theme-text-tertiary);
        letter-spacing: var(--theme-tracking-wider);
      "
    >
      {study.data.company}
    </p>

    <h3
      class="font-heading"
      style={`
        color: var(--theme-text-primary);
        font-weight: var(--theme-weight-heading);
        letter-spacing: var(--theme-tracking-tight);
        line-height: ${featured ? "var(--theme-lh-2xl)" : "var(--theme-lh-lg)"};
        font-size: ${featured ? "var(--theme-text-2xl)" : "var(--theme-text-lg)"};
        margin-top: var(--theme-space-1);
      `}
    >
      {study.data.title}
    </h3>

    <p
      class:list={[
        featured ? "" : "line-clamp-2",
      ]}
      style={`
        color: var(--theme-text-secondary);
        font-size: var(--theme-text-sm);
        line-height: var(--theme-lh-sm);
        margin-top: var(--theme-space-1);
      `}
    >
      {study.data.description}
    </p>


  </div>
</a>

<style>
  .case-study-card-thumb {
    box-shadow: var(--shadow-elevation-low);
    transition: transform 0.28s cubic-bezier(0.34, 1.4, 0.64, 1), box-shadow 0.28s cubic-bezier(0.34, 1.4, 0.64, 1);
    transform-origin: center;
  }
  .group:hover .case-study-card-thumb {
    transform: scale(1.02);
    box-shadow: var(--shadow-elevation-medium);
  }
  @media (prefers-reduced-motion: reduce) {
    .case-study-card-thumb {
      transition: none;
    }
    .group:hover .case-study-card-thumb {
      transform: none;
    }
  }
</style>
