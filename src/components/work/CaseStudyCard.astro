---
/**
 * CaseStudyCard — thumbnail + text for homepage and /work listing.
 * Dark Gravity: dimmed images that brighten on hover.
 */
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  study: CollectionEntry<"work">;
}

const { study } = Astro.props;
---

<a
  href={`/work/${study.id}`}
  data-goatcounter-click={`casestudy-click-${study.id}`}
  class="group block animate-in"
>
  {/* Thumbnail */}
  <div class="overflow-hidden" style="border-radius: 4px;">
    <Image
      src={study.data.thumbnail}
      alt={study.data.thumbnailAlt}
      widths={[400, 600, 800]}
      sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
      class="card-img w-full object-cover aspect-[16/10]"
    />
  </div>

  {/* Text */}
  <div style="padding-top: var(--theme-space-2);">
    <p
      class="text-xs font-semibold uppercase"
      style="
        color: #6B6560;
        letter-spacing: var(--theme-tracking-wider);
      "
    >
      {study.data.company}
    </p>

    <h3
      class="font-heading"
      style="
        color: #E8E4DF;
        font-weight: var(--theme-weight-heading);
        letter-spacing: var(--theme-tracking-tight);
        line-height: var(--theme-leading-snug);
        font-size: var(--theme-text-lg);
        margin-top: 0.25rem;
      "
    >
      {study.data.title}
    </h3>

    <p
      class="leading-relaxed line-clamp-2"
      style="
        color: #9B9590;
        font-size: var(--theme-text-sm);
        margin-top: var(--theme-space-1);
      "
    >
      {study.data.description}
    </p>
  </div>
</a>
