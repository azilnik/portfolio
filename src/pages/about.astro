---
/**
 * About page — /about
 *
 * The warmest surface in the portfolio. Personality-forward.
 * A hiring manager comes here to find out if they want to work
 * with this person, not to verify credentials.
 */
import PageLayout from "../layouts/PageLayout.astro";
import { Image } from "astro:assets";
import avatarImage from "../assets/images/avatar.jpg";

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ari Zilnik",
  url: "https://ari.design",
  image: "https://ari.design/og-default.png",
  jobTitle: "Head of Design",
  worksFor: {
    "@type": "Organization",
    name: "Join",
    url: "https://join.build",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Toronto",
    addressRegion: "Ontario",
    addressCountry: "Canada",
  },
  sameAs: [
    "https://www.linkedin.com/in/azilnik/",
    "https://github.com/azilnik",
  ],
  knowsAbout: [
    "Design leadership",
    "Product design",
    "Design systems",
    "Construction technology",
    "Developer tools",
    "Fintech",
    "Crypto infrastructure",
  ],
};
---

<PageLayout
  title="About Ari Zilnik — design leader in Toronto"
  description="About Ari Zilnik — design leader who builds products, teams, and the occasional over-engineered home automation."
  jsonLd={[personJsonLd]}
>
  <section
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div class="flex flex-col gap-8 md:flex-row md:gap-16 animate-in">

      {/* Left: content */}
      <div class="flex-1" style="max-width: var(--theme-prose-width);">
        <h1
          class="font-heading"
          style="
            color: var(--theme-text-primary);
            font-weight: var(--theme-weight-heading);
            letter-spacing: var(--theme-tracking-tight);
            line-height: var(--theme-leading-tight);
            font-size: var(--theme-text-5xl);
          "
        >
          About
        </h1>

        <div
          class="font-sans"
          style="
            color: var(--theme-text-secondary);
            font-size: var(--theme-text-lg);
            line-height: var(--theme-leading-relaxed);
            margin-top: var(--theme-space-5);
          "
        >
          <p>
            I run design at <a href="https://join.build/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-join" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Join</a>, a venture-backed construction platform used by 1,000+ companies including <a href="https://www.einpresswire.com/article/847639958/join-secures-growth-investment-from-construction-giants-dpr-construction-and-sto-building-group" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-einpresswire-dpr-sto" class="underline decoration-1 underline-offset-2" style="text-decoration-color: var(--theme-border-strong);">DPR and STO Building Group</a>. My team ships AI-powered tools that help project owners make faster decisions — and support tickets dropped 32% after we rebuilt the navigation.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            Before Join, I was the <a href="https://www.blockdaemon.com/blog/announcing-blockdaemons-acquisition-of-gravy" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-blockdaemon-acquisition" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">founding designer at Blockdaemon</a>, where I built the design org from one person to seven and shipped two zero-to-one products during a period the company went from seed stage to a <a href="https://www.coindesk.com/business/2021/09/21/blockchain-infrastructure-firm-blockdaemon-nabs-13b-valuation-in-155m-funding-round/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-coindesk-blockdaemon" class="underline decoration-1 underline-offset-2" style="text-decoration-color: var(--theme-border-strong);">$3.25B valuation</a> backed by Goldman Sachs and SoftBank.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            Before that, <a href="https://gradle.com/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-gradle" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">design lead at Gradle</a> (developer tools for Netflix and Salesforce) and <a href="https://corporate.walmart.com/news/2016/09/19/walmart-completes-acquisition-of-jet-com-inc" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-walmart-jet" class="underline decoration-1 underline-offset-2" style="text-decoration-color: var(--theme-border-strong);">design lead at Jet.com through Walmart's $3.3B acquisition</a>.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            I own six record players. My wife is very patient about this.
          </p>
        </div>

        <div style="margin-top: var(--theme-space-5);">
          <a
            href="mailto:ari@zilnik.com"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold transition-colors"
            style="background-color: var(--theme-text-primary); color: var(--theme-bg);"
            data-goatcounter-click="contact-about"
          >
            Get in touch
          </a>
        </div>
      </div>

      {/* Right: avatar — larger, sharp corners */}
      <div class="hidden md:block flex-shrink-0" style="padding-top: var(--theme-space-5);">
        <Image
          src={avatarImage}
          alt="Ari Zilnik"
          width={320}
          height={320}
          class="object-cover"
        />
      </div>
    </div>
  </section>
</PageLayout>
