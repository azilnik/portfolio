---
/**
 * About page — /about
 * Dark Gravity theme. Confident, declarative copy.
 */
import PageLayout from "../layouts/PageLayout.astro";
import { Image } from "astro:assets";
import avatarImage from "../assets/images/avatar.jpg";

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ari Zilnik",
  url: "https://ari.design",
  image: "https://ari.design/og-default.png",
  jobTitle: "Head of Design",
  worksFor: {
    "@type": "Organization",
    name: "Join",
    url: "https://join.build",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Toronto",
    addressRegion: "Ontario",
    addressCountry: "Canada",
  },
  sameAs: [
    "https://www.linkedin.com/in/azilnik/",
    "https://github.com/azilnik",
  ],
  knowsAbout: [
    "Design leadership",
    "Product design",
    "Design systems",
    "Construction technology",
    "Developer tools",
    "Fintech",
    "Crypto infrastructure",
  ],
};
---

<PageLayout
  title="About Ari Zilnik — design leader in Toronto"
  description="About Ari Zilnik — design leader who builds products, teams, and the occasional over-engineered home automation."
  jsonLd={[personJsonLd]}
>
  <section
    class="mx-auto px-6"
    style="
      max-width: 64rem;
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div class="flex flex-col gap-8 md:flex-row md:gap-16 animate-in">

      {/* Left: content */}
      <div class="flex-1" style="max-width: var(--theme-prose-width);">
        <h1
          class="font-heading"
          style="
            color: #E8E4DF;
            font-weight: var(--theme-weight-heading);
            letter-spacing: var(--theme-tracking-tight);
            line-height: var(--theme-leading-tight);
            font-size: var(--theme-text-5xl);
          "
        >
          About
        </h1>

        <div
          class="font-sans"
          style="
            color: #9B9590;
            font-size: var(--theme-text-lg);
            line-height: var(--theme-leading-relaxed);
            margin-top: var(--theme-space-5);
          "
        >
          <p style="color: #E8E4DF;">
            I was the first designer at Blockdaemon. When I left, there were seven. The company hit a $3.25B valuation.
          </p>

          <p style="margin-top: var(--theme-space-3); color: #E8E4DF;">
            Now I run design at Join, a construction platform used by 1,000+ companies. My team ships AI-powered tools. Last year our navigation rebuild dropped support tickets 32%.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            Before Blockdaemon: Gradle (developer tools for Netflix and Salesforce) and Jet.com (through Walmart's $3.3B acquisition).
          </p>

          <p style="margin-top: var(--theme-space-3);">
            I collect record players. I over-automate my house. I chase two daughters across Toronto.
          </p>
        </div>

        <div style="margin-top: var(--theme-space-5);">
          <a
            href="mailto:ari@zilnik.com"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold"
            style="background: #D4A853; color: #0D0D0D; border-radius: 4px;"
            data-goatcounter-click="contact-about"
          >
            Get in touch
          </a>
        </div>
      </div>

      {/* Right: avatar */}
      <div class="hidden md:block flex-shrink-0" style="padding-top: var(--theme-space-5);">
        <Image
          src={avatarImage}
          alt="Ari Zilnik"
          width={280}
          height={280}
          class="rounded-2xl object-cover"
          style="border: 2px solid #2A2825;"
        />
      </div>
    </div>
  </section>
</PageLayout>
