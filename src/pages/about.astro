---
/**
 * About page — /about
 *
 * Warm Signal: warmest copy, avatar with negative-margin overlap on desktop,
 * Fraunces heading, green CTA button.
 */
import PageLayout from "../layouts/PageLayout.astro";
import { Image } from "astro:assets";
import avatarImage from "../assets/images/avatar.jpg";

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ari Zilnik",
  url: "https://ari.design",
  image: "https://ari.design/og-default.png",
  jobTitle: "Head of Design",
  worksFor: {
    "@type": "Organization",
    name: "Join",
    url: "https://join.build",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Toronto",
    addressRegion: "Ontario",
    addressCountry: "Canada",
  },
  sameAs: [
    "https://www.linkedin.com/in/azilnik/",
    "https://github.com/azilnik",
  ],
  knowsAbout: [
    "Design leadership",
    "Product design",
    "Design systems",
    "Construction technology",
    "Developer tools",
    "Fintech",
    "Crypto infrastructure",
  ],
};
---

<PageLayout
  title="About Ari Zilnik — design leader in Toronto"
  description="About Ari Zilnik — design leader who builds products, teams, and the occasional over-engineered home automation."
  jsonLd={[personJsonLd]}
>
  <section
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div class="flex flex-col gap-8 md:flex-row md:gap-16 animate-in">

      {/* Left: content */}
      <div class="flex-1" style="max-width: var(--theme-prose-width);">
        <h1
          class="font-heading"
          style="
            color: var(--theme-text-primary);
            font-weight: 700;
            letter-spacing: var(--theme-tracking-tight);
            line-height: var(--theme-leading-tight);
            font-size: var(--theme-text-5xl);
          "
        >
          About
        </h1>

        <div
          class="font-sans"
          style="
            color: var(--theme-text-secondary);
            font-size: var(--theme-text-lg);
            line-height: var(--theme-leading-relaxed);
            margin-top: var(--theme-space-5);
          "
        >
          <p>
            I'm Ari. I run design at <a href="https://join.build/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-join" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Join</a>, where we build tools that help construction companies manage projects without wanting to throw their laptops. Before Join it was <a href="https://www.blockdaemon.com/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-blockdaemon" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Blockdaemon</a> -- crypto infrastructure, first designer, built the team from one to seven during a stretch where the company went from seed to <a href="https://www.coindesk.com/business/2021/09/21/blockchain-infrastructure-firm-blockdaemon-nabs-13b-valuation-in-155m-funding-round/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-coindesk-blockdaemon" class="underline decoration-1 underline-offset-2" style="text-decoration-color: var(--theme-border-strong);">$3.25B</a>. Before that, <a href="https://gradle.com/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-gradle" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Gradle</a> (developer tools used by Netflix and Salesforce) and <a href="https://corporate.walmart.com/news/2016/09/19/walmart-completes-acquisition-of-jet-com-inc" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-walmart-jet" class="underline decoration-1 underline-offset-2" style="text-decoration-color: var(--theme-border-strong);">Jet.com</a> (through Walmart's $3.3B acquisition).
          </p>

          <p style="margin-top: var(--theme-space-3);">
            The thread across all of it: I show up early, when nobody has a design opinion yet, and I leave behind a team and a system that don't need me.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            I have six record players and my wife remains remarkably patient about this. I also <a href="/work/ha-smart-hood-vent" class="underline decoration-1 underline-offset-2" style="text-decoration-color: var(--theme-border-strong);">over-automate everything</a> -- my kitchen range hood turns itself on when the stove lights. We spend most of our free time chasing our two girls across Toronto.
          </p>
        </div>

        <div style="margin-top: var(--theme-space-5);">
          <a
            href="mailto:ari@zilnik.com"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold transition-colors"
            style="background-color: #2A5F4F; color: #ffffff; border-radius: 4px;"
            data-goatcounter-click="contact-about"
          >
            Get in touch
          </a>
        </div>
      </div>

      {/* Right: avatar with negative-margin overlap on desktop */}
      <div class="hidden md:block flex-shrink-0" style="margin-top: -2rem;">
        <Image
          src={avatarImage}
          alt="Ari Zilnik"
          width={280}
          height={280}
          class="object-cover"
          style="border-radius: 8px; box-shadow: var(--theme-shadow-lg);"
        />
      </div>
    </div>
  </section>
</PageLayout>
