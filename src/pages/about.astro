---
/**
 * About page — /about
 *
 * The warmest surface in the portfolio. Personality-forward.
 * A hiring manager comes here to find out if they want to work
 * with this person, not to verify credentials.
 */
import PageLayout from "../layouts/PageLayout.astro";
import { Image } from "astro:assets";
import avatarImage from "../assets/images/avatar.jpg";

// Person JSON-LD on /about mirrors the homepage's so either page works as a
// structured-data entry point for crawlers. Duplication is expected for
// Person schema — Google resolves both to the same entity via sameAs.
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ari Zilnik",
  url: "https://ari.design",
  image: "https://ari.design/og-default.png",
  jobTitle: "Head of Design",
  worksFor: {
    "@type": "Organization",
    name: "Join",
    url: "https://join.build",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Toronto",
    addressRegion: "Ontario",
    addressCountry: "Canada",
  },
  sameAs: [
    "https://www.linkedin.com/in/azilnik/",
    "https://github.com/azilnik",
  ],
  knowsAbout: [
    "Design leadership",
    "Product design",
    "Design systems",
    "Construction technology",
    "Developer tools",
    "Fintech",
    "Crypto infrastructure",
  ],
};
---

<PageLayout
  title="About Ari Zilnik — design leader in Toronto"
  description="About Ari Zilnik — design leader who builds products, teams, and the occasional over-engineered home automation."
  jsonLd={[personJsonLd]}
>
  <section
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div class="flex flex-col gap-8 md:flex-row md:gap-16 animate-in">

      {/* Left: content */}
      <div class="flex-1" style="max-width: var(--theme-prose-width);">
        <h1
          class="font-heading"
          style="
            color: var(--theme-text-primary);
            font-weight: var(--theme-weight-heading);
            letter-spacing: var(--theme-tracking-tight);
            line-height: var(--theme-leading-tight);
            font-size: var(--theme-text-5xl);
          "
        >
          About
        </h1>

        <div
          class="font-sans"
          style="
            color: var(--theme-text-secondary);
            font-size: var(--theme-text-lg);
            line-height: var(--theme-leading-relaxed);
            margin-top: var(--theme-space-5);
          "
        >
          <p>
            I'm Head of Design at <a href="https://join.build/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-join" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Join</a>, a construction project management platform used by more than a thousand companies. I built the AI recommendation engine, rebuilt navigation around projects (32% drop in support tickets), and shipped the scenario planning view.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            Before Join I was the founding designer at <a href="https://www.blockdaemon.com/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-blockdaemon" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Blockdaemon</a>. I built the design team from one to seven as the company grew from seed to $3.25B, and shipped both the institutional staking dashboard and the self-serve node deployment flow.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            Earlier, I led design at <a href="https://gradle.com/" target="_blank" rel="noopener noreferrer" data-goatcounter-click="about-outbound-gradle" class="font-semibold underline decoration-1 underline-offset-2" style="color: var(--theme-text-primary); text-decoration-color: var(--theme-border-strong);">Gradle</a> (developer tools used by Netflix, Salesforce, and LinkedIn), where I replaced a scattered filtering UI with a single omnibar. And before that, design lead at Jet.com through Walmart's $3.3B acquisition.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            The through-line: I'm the designer companies hire when there isn't a design opinion yet — and I build a team, a system, and a craft worth keeping.
          </p>

          <p style="margin-top: var(--theme-space-3);">
            Toronto. Six record players. One <a href="/work/ha-smart-hood-vent" class="underline decoration-1 underline-offset-2" style="text-decoration-color: var(--theme-border-strong);">over-automated kitchen</a>.
          </p>
        </div>

        <div class="flex flex-wrap gap-3" style="margin-top: var(--theme-space-5);">
          <a
            href="/work"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold transition-colors"
            style="background-color: var(--theme-text-primary); color: var(--theme-bg-primary); border-radius: 4px;"
            data-goatcounter-click="see-work-about"
          >
            See my work
          </a>
          <a
            href="mailto:ari@zilnik.com"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold transition-colors"
            style="border: 1px solid var(--theme-border-strong); color: var(--theme-text-primary); border-radius: 4px;"
            data-goatcounter-click="contact-about"
          >
            Get in touch
          </a>
        </div>
      </div>

      {/* Right: avatar */}
      <div class="hidden md:block flex-shrink-0" style="padding-top: var(--theme-space-5);">
        <Image
          src={avatarImage}
          alt="Ari Zilnik"
          width={280}
          height={280}
          class="object-cover"
        />
      </div>
    </div>
  </section>
</PageLayout>
