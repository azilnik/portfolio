---
/**
 * About page — /about
 */
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="About" description="About Ari Zilnik — design leader with 13+ years of experience shipping products at the intersection of complex systems and human needs.">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="font-heading text-4xl font-bold text-gray-900 md:text-5xl">
      About me
    </h1>

    <div class="mt-8 space-y-6 text-lg leading-relaxed text-gray-600">
      <p>
        I'm <span class="font-semibold text-gray-900">Ari Zilnik</span>, a hands-on design leader with
        over 13 years of experience crafting digital products. I currently serve as
        <span class="font-semibold text-gray-900">Head of Design at Join</span>, where I lead product
        design, design systems, and team growth.
      </p>

      <p>
        Throughout my career, I've worked across <span class="font-semibold text-gray-900">construction tech, blockchain infrastructure, and developer tools</span> —
        always at the intersection of complex systems and human needs. I believe great design
        makes the complex feel simple.
      </p>

      <p>
        I'm equally comfortable leading a team of designers through a strategic initiative
        and rolling up my sleeves to ship pixels. That range — from org-level strategy to
        hands-on craft — is what I love most about this work.
      </p>

      <p>
        When I'm not designing, you'll find me fixing up vintage audio equipment,
        tinkering with gadgets, or exploring new cities.
      </p>
    </div>

    {/* CTA */}
    <div class="mt-12">
      <a
        href="mailto:ari@ari.design"
        class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-hover"
      >
        Get in touch
      </a>
    </div>
  </section>
</PageLayout>
