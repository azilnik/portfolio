---
/**
 * 404 page — shown when a visitor hits a URL that doesn't exist.
 */
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="Page Not Found">
  <section class="mx-auto max-w-3xl px-6 py-32 text-center">
    <p class="text-6xl font-bold text-gray-200">404</p>
    <h1 class="mt-4 font-heading text-2xl font-bold text-gray-900">
      Page not found
    </h1>
    <p class="mt-3 text-gray-500">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-gray-900 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-gray-800"
    >
      Go home
    </a>
  </section>
</PageLayout>
