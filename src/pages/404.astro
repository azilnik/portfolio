---
/**
 * 404 page — shown when a visitor hits a URL that doesn't exist.
 * Spacing uses the baseline-grid tokens so it matches the rest of the site.
 */
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Not found"
  description="The page you're looking for doesn't exist or has been moved. Browse case studies or head home."
>
  <section
    class="mx-auto text-center px-6"
    style="
      max-width: var(--theme-prose-width);
      padding-top: var(--theme-space-8);
      padding-bottom: var(--theme-space-8);
    "
  >
    <p
      class="font-heading"
      style="
        color: var(--theme-border-strong);
        font-size: var(--theme-text-6xl);
        font-weight: var(--theme-weight-heading);
        line-height: 1;
      "
    >
      404
    </p>
    <h1
      class="font-heading"
      style="
        color: var(--theme-text-primary);
        font-weight: var(--theme-weight-heading);
        font-size: var(--theme-text-2xl);
        margin-top: var(--theme-space-3);
      "
    >
      Page not found
    </h1>
    <p
      style="
        color: var(--theme-text-secondary);
        font-size: var(--theme-text-lg);
        margin-top: var(--theme-space-2);
      "
    >
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full px-7 py-3 text-sm font-semibold transition-colors"
      style="
        background-color: var(--theme-text-primary);
        color: var(--theme-bg);
        margin-top: var(--theme-space-5);
      "
    >
      Go home
    </a>
  </section>
</PageLayout>
