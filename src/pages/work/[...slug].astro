---
/**
 * Dynamic case study page — /work/[slug]
 *
 * Generates one page per case study in the `work` content collection.
 * Uses `getStaticPaths()` so Astro knows all the URLs at build time.
 * The MDX body is rendered inside the CaseStudyLayout.
 *
 * Computes prev/next adjacency from the sorted collection so the
 * CaseStudyNav component can link readers to adjacent case studies.
 */
import { getCollection, render } from "astro:content";
import CaseStudyLayout from "../../layouts/CaseStudyLayout.astro";

export async function getStaticPaths() {
  const work = (await getCollection("work", ({ data }) => !data.draft))
    .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

  return work.map((entry, index) => {
    const prev = index > 0 ? work[index - 1] : undefined;
    const next = index < work.length - 1 ? work[index + 1] : undefined;

    return {
      params: { slug: entry.id },
      props: {
        entry,
        prevStudy: prev
          ? { slug: prev.id, title: prev.data.title, company: prev.data.company }
          : undefined,
        nextStudy: next
          ? { slug: next.id, title: next.data.title, company: next.data.company }
          : undefined,
      },
    };
  });
}

const { entry, prevStudy, nextStudy } = Astro.props;
const { Content } = await render(entry);
---

<CaseStudyLayout
  title={entry.data.title}
  company={entry.data.company}
  role={entry.data.role}
  industry={entry.data.industry}
  description={entry.data.description}
  heroImage={entry.data.heroImage}
  metrics={entry.data.metrics}
  prevStudy={prevStudy}
  nextStudy={nextStudy}
>
  <Content />
</CaseStudyLayout>
