---
/**
 * Work listing page — /work
 *
 * Warm Signal: Fraunces heading, subheading, 2-col grid with green/terracotta
 * card treatment.
 */
import PageLayout from "../../layouts/PageLayout.astro";
import CaseStudyCard from "../../components/work/CaseStudyCard.astro";
import { getCollection } from "astro:content";

const allWork = (await getCollection("work", ({ data }) => !data.draft))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://ari.design" },
    { "@type": "ListItem", position: 2, name: "Case Studies", item: "https://ari.design/work" },
  ],
};
---

<PageLayout
  title="Work by Ari Zilnik — case studies"
  description="How Ari thinks about products, research, and shipping. Case studies from Join, Blockdaemon, Gradle, and side projects."
  jsonLd={[breadcrumbJsonLd]}
>
  <section
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-7);
    "
  >
    <div style="margin-bottom: var(--theme-space-5);">
      <h1
        class="font-heading"
        style="
          color: var(--theme-text-primary);
          font-weight: 700;
          letter-spacing: var(--theme-tracking-tight);
          line-height: var(--theme-leading-tight);
          font-size: var(--theme-text-5xl);
        "
      >
        Work
      </h1>

      <p
        style="
          color: var(--theme-text-secondary);
          font-size: var(--theme-text-xl);
          line-height: var(--theme-leading-normal);
          margin-top: var(--theme-space-2);
          max-width: 48ch;
        "
      >
        How I think about products, research, and shipping.
      </p>
    </div>

    {allWork.length > 0 ? (
      <div
        class="grid grid-cols-1 md:grid-cols-2"
        style="gap: var(--theme-space-4);"
      >
        {allWork.map((study) => (
          <CaseStudyCard study={study} />
        ))}
      </div>
    ) : (
      <p style="color: var(--theme-text-tertiary);">
        Case studies coming soon.
      </p>
    )}
  </section>
</PageLayout>
