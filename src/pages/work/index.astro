---
/**
 * Work listing page — /work
 *
 * Shows all non-draft case studies. Left-aligned header with a clean
 * grid below. Matches the homepage's visual language.
 */
import PageLayout from "../../layouts/PageLayout.astro";
import CaseStudyCard from "../../components/work/CaseStudyCard.astro";
import { getCollection } from "astro:content";

const allWork = (await getCollection("work", ({ data }) => !data.draft))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

// BreadcrumbList for /work — a two-level breadcrumb that Google can render
// in the SERP, replacing the URL with the breadcrumb path on mobile.
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://ari.design" },
    { "@type": "ListItem", position: 2, name: "Case Studies", item: "https://ari.design/work" },
  ],
};
---

<PageLayout
  title="Work by Ari Zilnik — case studies"
  description="How Ari thinks, leads, and builds. Case studies from Join, Blockdaemon, Gradle, and side projects across construction tech, fintech, and developer tools."
  jsonLd={[breadcrumbJsonLd]}
>
  <section
    class="mx-auto px-6"
    style="
      max-width: var(--theme-content-width);
      padding-top: var(--theme-space-7);
      padding-bottom: var(--theme-space-7);
    "
  >
    {/* Page header — left-aligned, no eyebrow. Clean. */}
    <div style="margin-bottom: var(--theme-space-5);">
      <h1
        class="font-heading"
        style="
          color: var(--theme-text-primary);
          font-weight: var(--theme-weight-heading);
          letter-spacing: var(--theme-tracking-tight);
          line-height: var(--theme-leading-tight);
          font-size: var(--theme-text-5xl);
        "
      >
        Ships
      </h1>
    </div>

    {/* Case study grid — single column, gallery feel with generous spacing */}
    {allWork.length > 0 ? (
      <div
        style="
          display: grid;
          grid-template-columns: 1fr;
          gap: 4rem;
        "
      >
        {allWork.map((study) => (
          <CaseStudyCard study={study} />
        ))}
      </div>
    ) : (
      <p style="color: var(--theme-text-tertiary);">
        Case studies coming soon.
      </p>
    )}
  </section>
</PageLayout>
