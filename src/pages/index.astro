---
/**
 * Homepage — Hero → Testimonials → Work → Side Projects.
 */
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/home/Hero.astro";
import TestimonialCarousel from "../components/home/TestimonialCarousel.astro";
import WorkSection from "../components/home/WorkSection.astro";
import SideProjects from "../components/home/SideProjects.astro";

// Person JSON-LD anchors the personal brand for knowledge-panel surfaces.
// Google, Bing, and LLM crawlers use this to build a structured representation
// of who the site is about. `sameAs` cross-references the public social
// identities so the entity disambiguates cleanly.
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ari Zilnik",
  url: "https://ari.design",
  image: "https://ari.design/og-default.png",
  jobTitle: "Head of Design",
  worksFor: {
    "@type": "Organization",
    name: "Join",
    url: "https://join.build",
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Toronto",
    addressRegion: "Ontario",
    addressCountry: "Canada",
  },
  sameAs: [
    "https://www.linkedin.com/in/azilnik/",
    "https://github.com/azilnik",
  ],
  knowsAbout: [
    "Design leadership",
    "Product design",
    "Design systems",
    "Construction technology",
    "Developer tools",
    "Fintech",
    "Crypto infrastructure",
  ],
};
---

<PageLayout
  title="Ari Zilnik — Head of Design at Join"
  description="Ari Zilnik — Head of Design at Join. Products, teams, and systems in construction, fintech, and developer tools."
  jsonLd={[personJsonLd]}
>
  <Hero />
  <TestimonialCarousel />
  <WorkSection />
  <SideProjects />
</PageLayout>
